// FONCE IMPORTER — pickup data sent by the Chrome extension
// URL format: #import?fonce_import=1&source=...&title=...&price=...&image=...&variants=...
// ------------------------------------------------------------
(function pickupImportFromExtension() {
  try {
    const hash = location.hash || '';
    if (!hash.startsWith('#import')) return;
    const qIdx = hash.indexOf('?');
    if (qIdx === -1) return;
    const params = new URLSearchParams(hash.slice(qIdx + 1));
    if (params.get('fonce_import') !== '1') return;

    // Stash on a global so the Add Product view can read it on first render
    window.__fonceImport = {
      source: params.get('source') || '',
      title: params.get('title') || '',
      image: params.get('image') || '',
      price: parseFloat(params.get('price') || '') || null,
      description: params.get('desc') || '',
      variants: (() => {
        try { return JSON.parse(params.get('variants') || '[]'); } catch (e) { return []; }
      })()
    };

    // Clean the URL so refresh doesn't re-trigger
    history.replaceState(null, '', location.pathname + location.search);

    // If the user is signed in, jump straight to Add Product. Otherwise the
    // login flow will pick it up after they sign in (handled below).
    if (state.currentUser) {
      state.view = 'addProduct';
    } else {
      // Save the intent for after auth
      window.__fonceImportPending = true;
      toast('Sign in to finish importing this product.');
    }
  } catch (e) {
    console.warn('[Fonce] Import pickup failed:', e);
  }
})();


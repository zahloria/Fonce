    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
    border-radius: 2px;
  }
  .template-option:hover { border-color: var(--accent-deep); }
  .template-option.active {
    border-color: var(--accent);
    background: var(--bg-soft);
  }
  .template-preview {
    background: var(--bg);
    height: 90px;
    margin-bottom: 1rem;
    padding: 0.5rem;
    display: flex;
    gap: 4px;
    border: 1px solid var(--border);
  }
  .tpl-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px; flex: 1; }
  .tpl-grid > div { background: var(--accent-deep); opacity: 0.4; }

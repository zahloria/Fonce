  .phone-stage {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
  }

  /* The phone */
  .phone-frame {
    position: relative;
    width: 320px;
    height: 660px;
    background: linear-gradient(145deg, #2a2a2c, #1a1a1c);
    border-radius: 50px;
    padding: 12px;
    box-shadow:
      0 30px 80px -20px rgba(0,0,0,0.7),
      0 0 0 1px rgba(255,255,255,0.04),
      inset 0 0 0 2px rgba(255,255,255,0.05);
  }
  .phone-notch {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 95px;
    height: 26px;
    background: #0a0a0a;
    border-radius: 14px;
    z-index: 10;
  }
  .phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: #fff;
    border-radius: 38px;
    overflow: hidden;
  }
  .phone-home-indicator {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 110px;
    height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,0.4);
  }

  /* Both screens absolute-positioned for transitions */
  .ig-screen, .ps-screen {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    overflow-x: hidden;
    transition: opacity 0.45s ease, transform 0.5s ease;
  }
  .ig-screen { background: #fff; color: #262626; }
  .ig-screen.hide {
    opacity: 0;
    transform: translateX(-30px);
    pointer-events: none;
  }
  .ps-screen {
    opacity: 0;
    transform: translateX(30px);
    pointer-events: none;
  }
  .ps-screen.show {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  /* IG status bar */
  .ig-statusbar, .ps-statusbar {

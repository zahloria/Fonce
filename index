  .vip-banner .btn-vip-upgrade {
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.02em;
    box-shadow: 0 0 0 0 rgba(212,175,55,0);
    animation: vipGlow 5s ease-in-out infinite;
    transition: transform 0.2s ease;
  }
  .vip-banner .btn-vip-upgrade:hover {
    animation-duration: 1.2s;
    transform: translateY(-1px);
  }
  .vip-banner .btn-vip-upgrade::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 35%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255, 248, 220, 0.85) 50%,
      transparent 80%
    );
    transform: translateX(-100%);
    animation: vipShine 5s ease-in-out infinite;
    pointer-events: none;

  }
  .variant-chip-label {
    font-weight: 500;
  }
  .variant-chip-price {
    color: var(--accent);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .variant-chip.active .variant-chip-price {
    color: var(--accent-bright);
  }
  .texture-colors-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.25rem;
    border-radius: 4px;
    margin-top: 0.85rem;
  }
  .tc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .tc-title {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--fg);
    font-weight: 500;
  }
  .tc-reset {
    background: transparent;
    border: none;
    color: var(--fg-muted);
    font-size: 0.75rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  .tc-reset:hover { color: var(--accent); }
  .tc-fields {
    display: grid;
    grid-template-columns: repeat(3, 1fr);

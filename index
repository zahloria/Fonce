  .sg-tier-section.tier-generic {
    border-color: var(--border);
    background: var(--bg-elevated);
  }
  .sg-tier-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.6rem;
  }
  .sg-tier-marker {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .tier-premium .sg-tier-marker { background: #a78bfa; color: #1a1023; }
  .tier-verified .sg-tier-marker { background: var(--accent); color: var(--bg); }
  .tier-generic .sg-tier-marker { background: var(--border); color: var(--fg-muted); }
  .sg-tier-title {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 600;
  }
  .sg-tier-sub { color: var(--fg-muted); font-size: 0.82rem; margin-top: 2px; }
  .sg-tier-desc {
    color: var(--fg-muted);
    font-size: 0.88rem;
    line-height: 1.55;
    margin-bottom: 0.9rem;
  }

  .sg-source-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.6rem;
  }
  .sg-source {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.75rem 0.85rem;

function showReviewModal(influencerUsername) {
  if (document.getElementById('review-modal')) return;
  const reviewable = getReviewableProducts(influencerUsername);
  if (reviewable.length === 0) return;

  let selectedRating = 0;
  let selectedProductId = reviewable[0].id;
  let imageDataUrl = null;

  const overlay = $(`
    <div id="review-modal" class="upgrade-overlay">
      <div class="upgrade-modal review-modal">
        <button class="upgrade-close" aria-label="Close">&times;</button>
        <div class="upgrade-eyebrow">Review</div>
        <h2>Rate your purchase</h2>
        <p class="upgrade-sub">Share your experience from @${escapeHtml(influencerUsername)}'s showcase.</p>

        ${reviewable.length > 1 ? `
          <div class="review-form-section">
            <label class="review-label">Which product?</label>
            <div class="product-picker" id="product-picker">
              ${reviewable.map((p, i) => `
                <div class="product-pick ${i === 0 ? 'active' : ''}" data-product-id="${p.id}">
                  <div class="img" style="background-image:url('${escapeHtml(p.image || '').slice(0,500)}')"></div>
                  <div class="title">${escapeHtml(p.title)}</div>
                </div>
              `).join('')}
            </div>
          </div>
        ` : `
          <div class="review-form-section">
            <label class="review-label">Reviewing</label>
            <div class="single-product-display">
              <div class="img" style="background-image:url('${escapeHtml(reviewable[0].image || '').slice(0,500)}')"></div>
              <div class="title">${escapeHtml(reviewable[0].title)}</div>
            </div>
          </div>
        `}

        <div class="review-form-section">
          <label class="review-label">Your rating</label>
          <div class="star-rating" data-interactive="1" id="rating-input">
            ${[1,2,3,4,5].map(i => `
              <svg class="rstar interactive" width="32" height="32" viewBox="0 0 24 24" data-value="${i}">
                <path d="M 12 2.5 L 14.4 8.8 L 21 9.1 L 15.8 13.2 L 17.6 19.7 L 12 16 L 6.4 19.7 L 8.2 13.2 L 3 9.1 L 9.6 8.8 Z"/>
              </svg>
            `).join('')}
          </div>
        </div>

        <div class="review-form-section">
          <label class="review-label">Comment</label>
          <textarea id="review-comment" rows="4" placeholder="How was the product? Quality, fit, shipping..."></textarea>
        </div>

        <div class="review-form-section">
          <label class="review-label">Photo (optional)</label>
          <input type="file" id="review-image" accept="image/*" style="display:none" />
          <button type="button" class="btn btn-sm" id="review-upload-btn">Add a photo</button>
          <span class="review-upload-hint">Show off your purchase. Max 2MB.</span>
          <div class="review-image-preview" id="review-image-preview" style="display:none"></div>
        </div>

        <div id="review-err"></div>
        <button class="btn btn-primary btn-block" id="submit-review-btn">Post review</button>
        <button class="upgrade-later" id="cancel-review">Maybe later</button>
      </div>
    </div>
  `);
  document.body.appendChild(overlay);
  document.body.style.overflow = 'hidden';

  const close = () => {
    overlay.remove();
    document.body.style.overflow = '';
  };
  overlay.querySelector('.upgrade-close').onclick = close;
  overlay.querySelector('#cancel-review').onclick = close;
  overlay.onclick = (e) => { if (e.target === overlay) close(); };

  // Product picker (only if multiple)
  const picker = overlay.querySelector('#product-picker');
  if (picker) {
    picker.querySelectorAll('.product-pick').forEach(p => {
      p.onclick = () => {
        picker.querySelectorAll('.product-pick').forEach(x => x.classList.remove('active'));
        p.classList.add('active');
        selectedProductId = p.dataset.productId;
      };
    });
  }

  // Interactive star rating
  const stars = overlay.querySelectorAll('#rating-input .rstar');
  const updateStars = (val) => {
    stars.forEach((s, i) => s.classList.toggle('filled', i < val));
  };
  stars.forEach(s => {
    s.onmouseenter = () => updateStars(+s.dataset.value);
    s.onclick = () => {
      selectedRating = +s.dataset.value;
      updateStars(selectedRating);
    };
  });
  overlay.querySelector('#rating-input').onmouseleave = () => updateStars(selectedRating);

  // Image upload
  const fileInput = overlay.querySelector('#review-image');
  const uploadBtn = overlay.querySelector('#review-upload-btn');
  const preview = overlay.querySelector('#review-image-preview');
  uploadBtn.onclick = () => fileInput.click();
  fileInput.onchange = (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 3 * 1024 * 1024) {
      toast('Image too large. Try under 2MB.');
      return;
    }
    const reader = new FileReader();
    reader.onload = (ev) => {
      imageDataUrl = ev.target.result;
      preview.style.display = 'block';
      preview.style.backgroundImage = `url('${imageDataUrl}')`;
      uploadBtn.textContent = 'Change photo';
    };
    reader.readAsDataURL(file);
  };

  // Submit
  overlay.querySelector('#submit-review-btn').onclick = () => {
    const errEl = overlay.querySelector('#review-err');
    if (selectedRating < 1) {
      errEl.innerHTML = '<div class="error">Pick a star rating.</div>';
      return;
    }
    const comment = overlay.querySelector('#review-comment').value.trim();
    addReview({
      influencerUsername,
      productId: selectedProductId,
      rating: selectedRating,
      comment,
      image: imageDataUrl
    });
    close();
    toast('Review posted.');
    render();
  };
}


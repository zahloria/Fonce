  @media (max-width: 768px) {
    .tc-fields { grid-template-columns: 1fr; }
  }
  .tc-field label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
    font-weight: 500;
  }
  .tc-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .tc-row input[type="color"] {
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: transparent;
    cursor: pointer;
    padding: 2px;
  }
  .tc-row input[type="text"] {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);

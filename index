  /* ---- Live overlay (animated ambient dots over showcase) ---- */
  #live-overlay.live-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .live-dot {
    position: absolute;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    filter: blur(28px);
    animation: liveDotFloat 30s infinite ease-in-out;
    will-change: transform, opacity;
  }
  .live-overlay.live-starry .live-dot {
    background: radial-gradient(circle,
      color-mix(in srgb, var(--accent) 65%, white 25%) 0%,
      color-mix(in srgb, var(--accent) 30%, transparent) 45%,
      transparent 75%);
  }
  .live-overlay.live-velvet .live-dot {
    background: radial-gradient(circle,
      color-mix(in srgb, var(--accent) 60%, white 15%) 0%,
      color-mix(in srgb, var(--accent) 35%, transparent) 50%,
      transparent 75%);
  }
  @keyframes liveDotFloat {
    0%   { transform: translate(0, 0) scale(0.95); opacity: 0.5; }
    25%  { transform: translate(80px, -60px) scale(1.15); opacity: 0.7; }
    50%  { transform: translate(140px, 80px) scale(0.85); opacity: 0.4; }
    75%  { transform: translate(-50px, 100px) scale(1.1); opacity: 0.8; }
    100% { transform: translate(0, 0) scale(0.95); opacity: 0.5; }

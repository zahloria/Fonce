  const purchased = getPurchasedProductsFrom(influencerUsername);
  if (purchased.length === 0) return { ok: false, reason: 'Buy a product first to leave a review.' };
  const reviewable = getReviewableProducts(influencerUsername);
  if (reviewable.length === 0) return { ok: false, reason: 'You\'ve reviewed all your purchases.' };

    if (!isOpen) editTitleInput.focus();
  };

  editUploadBtn.onclick = () => editImageFile.click();
  editImageFile.onchange = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const MAX_SIZE = 2 * 1024 * 1024;
    if (file.size > MAX_SIZE) {
      toast('Image too large. Please use a file under 2 MB.');
      editImageFile.value = '';
      return;
    }
    if (!file.type.startsWith('image/')) {
      toast('Please choose an image file.');
      editImageFile.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = (ev) => {
      editImageInput.value = ev.target.result;

/* ============================================================
   FONCE REWARDS — VIP buyers earn 5% of listed price as
   redeemable credit. Expires 90 days from earning. Spent
   FIFO so oldest credit is used first (avoids waste).
   ============================================================ */
const REWARDS_EXPIRATION_DAYS = 90;
const REWARDS_EARN_RATE = 0.05;
const REWARDS_MS_PER_DAY = 24 * 60 * 60 * 1000;

function getActiveRewards(user) {
  if (!user || !user.rewards) return [];
  const now = Date.now();
  return user.rewards.filter(r => r.expiresAt > now && r.spent < r.amount);
}

function getRewardsBalance(user) {
  return getActiveRewards(user).reduce((sum, r) => sum + (r.amount - r.spent), 0);
}

function getNextExpiration(user) {
  const active = getActiveRewards(user);
  if (active.length === 0) return null;
  let earliest = active[0];
  for (const r of active) if (r.expiresAt < earliest.expiresAt) earliest = r;
  return { expiresAt: earliest.expiresAt, amount: earliest.amount - earliest.spent };
}

function awardRewards(user, amount, sourceOrderId) {
  if (amount <= 0) return null;
  if (!user.rewards) user.rewards = [];
  const now = Date.now();
  const entry = {
    id: 'rwd_' + Date.now() + '_' + Math.floor(Math.random() * 10000),
    amount: Math.round(amount * 100) / 100,
    earnedAt: now,
    expiresAt: now + (REWARDS_EXPIRATION_DAYS * REWARDS_MS_PER_DAY),
    source: sourceOrderId,
    spent: 0
  };
  user.rewards.push(entry);
  return entry;
}

function spendRewards(user, amount) {
  if (amount <= 0 || !user || !user.rewards) return 0;
  const active = getActiveRewards(user).slice().sort((a, b) => a.earnedAt - b.earnedAt);
  let remaining = amount;
  for (const entry of active) {
    if (remaining <= 0.005) break;
    const available = entry.amount - entry.spent;
    const toSpend = Math.min(available, remaining);
    entry.spent = Math.round((entry.spent + toSpend) * 100) / 100;
    remaining -= toSpend;
  }
  return Math.round((amount - remaining) * 100) / 100;
}

function formatRewardsExpDate(timestamp) {
  return new Date(timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function rewardsDaysUntil(timestamp) {
  return Math.max(0, Math.ceil((timestamp - Date.now()) / REWARDS_MS_PER_DAY));
}

function placeCartOrders(buyerEmail, shippingAddr, rewardsApplied) {
  const cart = getCart();
  const buyer = state.users[state.currentUser];
  const orders = [];
  const subtotal = cart.reduce((sum, item) => sum + item.product.listedPrice, 0);
  const rewardsToSpend = Math.max(0, Math.min(rewardsApplied || 0, getRewardsBalance(buyer), subtotal));
  let actuallySpent = 0;
  if (rewardsToSpend > 0 && buyer) {
    actuallySpent = spendRewards(buyer, rewardsToSpend);
  }

  // Distribute rewardsApplied across cart items proportionally to listed price
  // (so each order line records its share)
  for (const item of cart) {
    const product = item.product;
    const platformFee = +(product.listedPrice * 0.10).toFixed(2);
    const influencerProfit = +(product.markup - platformFee).toFixed(2);
    const itemShareOfRewards = subtotal > 0
      ? +((product.listedPrice / subtotal) * actuallySpent).toFixed(2)
      : 0;
    const order = {
      id: 'o_' + Date.now() + '_' + Math.floor(Math.random() * 10000),
      productId: product.id,
      productTitle: product.title,
      productImage: product.image,
      buyerEmail,
      buyer: state.currentUser,
      shippingAddr,
      influencer: item.influencerUsername,
      listedPrice: product.listedPrice,
      sourcePrice: product.sourcePrice,
      markup: product.markup,
      platformFee,
      influencerProfit,
      rewardsApplied: itemShareOfRewards,
      cashPaid: +(product.listedPrice - itemShareOfRewards).toFixed(2),
      buyerWasVip: !!(buyer && buyer.isVip),
      createdAt: Date.now()
    };
    state.orders.unshift(order);
    orders.push(order);
  }

  // Award rewards if buyer is VIP — 5% of listed price total
  let rewardsEarned = 0;
  if (buyer && buyer.isVip) {
    rewardsEarned = +(subtotal * REWARDS_EARN_RATE).toFixed(2);
    if (rewardsEarned > 0) {
      const sourceOrderId = orders.length > 0 ? orders[0].id : 'cart_' + Date.now();
      awardRewards(buyer, rewardsEarned, sourceOrderId);
    }
  }

  state.lastPurchase = {
    type: 'cart',
    itemCount: orders.length,
    rewardsEarned,
    rewardsApplied: actuallySpent
  };
  clearCart();
  save();
  return orders;
}


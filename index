  /* ---- Theme picker ---- */
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }
  .theme-option {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 2px;
    overflow: hidden;
    text-align: left;
  }
  .theme-option:hover { border-color: var(--accent-deep); }
  .theme-option.active { border-color: var(--accent); }
  .theme-swatch {
    height: 80px;
    position: relative;
    overflow: hidden;
  }
  .theme-swatch::before {
    content: '';
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--swatch-accent);
    box-shadow: 0 0 0 2px var(--swatch-bg);
  }
  .theme-swatch::after {
    content: 'Aa';
    position: absolute;
    top: 14px;
    left: 14px;
    color: var(--swatch-fg);
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 500;
  }
  .theme-option .label {
    padding: 0.75rem 1rem;
    font-family: var(--serif);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .theme-option.custom .theme-swatch {
    background:
      linear-gradient(
        to right,
        var(--cs-bg, #0a0806) 0%,
        var(--cs-bg, #0a0806) 33.33%,
        var(--cs-fg, #f5efe4) 33.33%,
        var(--cs-fg, #f5efe4) 66.66%,
        var(--cs-acc, #c9a961) 66.66%,
        var(--cs-acc, #c9a961) 100%
      );
  }
  .theme-option.custom .theme-swatch::after { content: ''; }
  .theme-option.custom .theme-swatch::before { display: none; }
  @keyframes gradientShift {
    0%,100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .theme-option.ombre-tile .theme-swatch::after,
  .theme-option.ombre-tile .theme-swatch::before { display: none; }
  .theme-option.image-tile .theme-swatch {
    background: #1a1410;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg-muted);
  }
  .theme-option.image-tile .theme-swatch::after,
  .theme-option.image-tile .theme-swatch::before { display: none; }
  .image-icon {
    width: 32px;
    height: 32px;
  }

  .custom-colors {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.25rem;
    margin-top: 1rem;
    display: none;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .custom-colors.show { display: grid; }
  .ombre-panel.show { grid-template-columns: repeat(4, 1fr); }
  .color-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .color-field label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .color-field-row { display: flex; gap: 0.5rem; align-items: center; }
  .color-field input[type="color"] {
    width: 42px;
    height: 42px;
    padding: 0;
    border: 1px solid var(--border);
    background: var(--bg);
    cursor: pointer;
    border-radius: 2px;
  }
  .color-field input[type="text"] {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--fg);
    font-family: monospace;
    font-size: 0.85rem;
    border-radius: 2px;
  }
  .color-field input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
    height: 4px;
  }

  .image-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.25rem;
    margin-top: 1rem;
    display: none;
  }
  .image-panel.show { display: block; }

  /* ---- Reviews section ---- */
  .reviews-section {
    margin-top: 6rem;
    padding-top: 4rem;
    border-top: 1px solid var(--border);
  }
  .reviews-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .reviews-header h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 2rem;
    font-variation-settings: var(--font-variation, "opsz" 144, "SOFT" 50);
  }
  .reviews-summary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .reviews-rating {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    margin-left: 0.3rem;
  }
  .reviews-count {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }
  .reviews-empty {
    color: var(--fg-muted);
    font-style: italic;
    text-align: center;
    padding: 2rem 0;
    font-family: var(--serif);
  }

  .star-rating {
    display: inline-flex;
    gap: 3px;
    align-items: center;
  }
  .rstar {
    transition: transform 0.15s ease;
  }
  .rstar path {
    fill: transparent;
    stroke: rgba(212,175,55,0.3);
    stroke-width: 2.4;
    stroke-linejoin: round;
    stroke-linecap: round;
    transition: fill 0.2s ease, stroke 0.2s ease;
  }
  .rstar.filled path {
    fill: #6b5318;
    stroke: url(#fonceStarGrad);
    stroke-width: 2.6;
  }
  .rstar.interactive { cursor: pointer; }
  .rstar.interactive:hover { transform: scale(1.15); }

  .reviews-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .review-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 4px;
  }
  .review-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }
  .review-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--accent-deep);
    color: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .review-meta {
    flex: 1;
    min-width: 0;
  }
  .review-name {
    font-family: var(--serif);
    font-weight: 500;
    color: var(--fg);
    font-size: 1rem;
  }
  .review-time {
    color: var(--fg-dim);
    font-size: 0.75rem;
  }
  .review-comment {
    color: var(--fg-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }
  .review-image {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .review-cta {
    text-align: center;
    margin-top: 2rem;
  }
  .review-cta-msg {
    color: var(--fg-muted);
    font-size: 0.9rem;
    font-style: italic;
  }
  .review-cta-msg a {
    color: var(--accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ---- Review modal form ---- */
  .review-modal { text-align: left; }
  .review-modal h2 { text-align: center; }
  .review-modal .upgrade-sub { text-align: center; }
  .review-form-section {
    margin-bottom: 1.5rem;
  }
  .review-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.6rem;
    font-weight: 500;
  }
  .review-modal #rating-input {
    justify-content: center;
    gap: 4px;
  }
  .review-modal textarea {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 0.75rem 0.85rem;
    font-family: var(--sans);
    font-size: 0.9rem;
    border-radius: 2px;
    resize: vertical;
    min-height: 80px;
  }
  .review-modal textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  .review-upload-hint {
    color: var(--fg-dim);
    font-size: 0.75rem;
    margin-left: 0.75rem;
  }
  .review-image-preview {
    width: 100%;
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
    border: 1px solid var(--border);
    border-radius: 4px;
    margin-top: 0.75rem;
  }

  /* ---- Purple floating review modal (post-purchase) ---- */
  .review-modal-floating {
    background: linear-gradient(165deg, #4a2557 0%, #3d1f47 50%, #2e1736 100%) !important;
    border: 1px solid rgba(212,175,55,0.25) !important;
    border-radius: 28px !important;
    box-shadow:
      0 30px 60px -15px rgba(0,0,0,0.7),
      0 0 80px -20px rgba(212,175,55,0.25),
      inset 0 1px 0 rgba(255,255,255,0.06) !important;
    color: #f5efe4;
    padding: 2.5rem 2.25rem !important;
    max-width: 480px !important;
  }
  .review-modal-floating::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(212,175,55,0.5) 50%, transparent 100%);
    border-radius: 28px 28px 0 0;
    pointer-events: none;
  }
  .floating-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #d4af37;
    text-align: center;
    margin-bottom: 0.85rem;
    font-weight: 500;
  }
  .review-modal-floating h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.85rem;
    text-align: center;
    color: #f5efe4;
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }
  .review-modal-floating .upgrade-sub {
    text-align: center;
    color: rgba(245,239,228,0.7);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .review-modal-floating .review-label {
    color: rgba(245,239,228,0.55);
  }
  .review-modal-floating textarea {
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(212,175,55,0.18);
    color: #f5efe4;
  }
  .review-modal-floating textarea::placeholder {
    color: rgba(245,239,228,0.35);
  }
  .review-modal-floating textarea:focus {
    border-color: #d4af37;
  }
  .review-modal-floating .upgrade-close {
    color: rgba(245,239,228,0.5);
  }
  .review-modal-floating .upgrade-close:hover {
    color: #f5efe4;
  }
  .review-modal-floating .review-upload-hint {
    color: rgba(245,239,228,0.4);
  }
  .review-modal-floating .btn-sm {
    background: rgba(212,175,55,0.12);
    color: #f5efe4;
    border: 1px solid rgba(212,175,55,0.3);
  }
  .review-modal-floating .btn-sm:hover {
    background: rgba(212,175,55,0.22);
  }
  .review-modal-floating .btn-primary {
    background: #d4af37;
    color: #2e1736;
    border: none;
    font-weight: 600;
    margin-top: 0.5rem;
  }
  .review-modal-floating .btn-primary:hover {
    background: #ecc960;
  }
  .review-modal-floating .upgrade-later {
    color: rgba(245,239,228,0.55);
  }
  .review-modal-floating .upgrade-later:hover {
    color: #f5efe4;
  }
  .review-modal-floating #rating-input {
    justify-content: center;
    gap: 6px;
    margin-top: 0.25rem;
  }

  /* Product card inside floating modal (single-buy) */
  .floating-product {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(212,175,55,0.15);
    border-radius: 10px;
    padding: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .floating-product .img {
    width: 56px;
    height: 56px;
    background-size: cover;
    background-position: center;
    border-radius: 6px;
    flex-shrink: 0;
    background-color: rgba(0,0,0,0.4);
  }
  .floating-product .info {
    flex: 1;
    min-width: 0;
  }
  .floating-product .title {
    font-family: var(--serif);
    color: #f5efe4;
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .floating-product .creator {
    color: rgba(245,239,228,0.55);
    font-size: 0.78rem;
  }

  /* Fonce mark inside cart-checkout floating modal */
  .floating-fonce-mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .fonce-mark-name {
    font-family: var(--serif);
    letter-spacing: 0.2em;
    color: #d4af37;
    font-size: 0.85rem;
    font-weight: 500;
  }

  /* Product picker inside review modal */
  .product-picker {
    display: flex;
    gap: 0.6rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
  }
  .product-pick {
    flex: 0 0 110px;
    cursor: pointer;
    border: 2px solid var(--border);
    border-radius: 6px;
    padding: 0.4rem;
    background: var(--bg);
    transition: border-color 0.15s, transform 0.15s;
  }
  .product-pick:hover {
    border-color: var(--accent-deep);
    transform: translateY(-1px);
  }
  .product-pick.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }
  .product-pick .img {
    width: 100%;
    aspect-ratio: 1;
    background-size: cover;
    background-position: center;
    border-radius: 3px;
    background-color: var(--bg-elevated);
    margin-bottom: 0.4rem;
  }
  .product-pick .title {
    font-size: 0.72rem;
    color: var(--fg);
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .single-product-display {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.6rem;
  }
  .single-product-display .img {
    width: 56px;
    height: 56px;
    background-size: cover;
    background-position: center;
    border-radius: 4px;
    flex-shrink: 0;
    background-color: var(--bg-elevated);
  }
  .single-product-display .title {
    font-family: var(--serif);
    color: var(--fg);
    font-size: 0.95rem;
  }

  /* Review product context */
  .review-product {
    color: var(--accent);
    font-weight: 500;
  }

  /* Review reply (creator's response) */
  .review-reply {
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    background: rgba(212,175,55,0.04);
    border-left: 2px solid var(--accent);
    border-radius: 0 4px 4px 0;
  }
  .review-reply-head {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.6rem;
  }
  .review-avatar-creator {
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    color: var(--bg);
    width: 30px;
    height: 30px;
    font-size: 0.85rem;
  }
  .creator-tag {
    font-size: 0.65rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-left: 0.4rem;
    background: rgba(212,175,55,0.12);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
  }
  .review-reply .review-comment {
    margin: 0;
    font-size: 0.9rem;
  }

  /* Dashboard product card review badge */
  .product-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    min-height: 18px;
  }
  .product-views {
    color: var(--fg-dim);
    font-size: 0.72rem;
  }
  .product-reviews-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--fg-muted);
  }
  .product-reviews-badge .star-rating { gap: 1px; }
  .unreplied-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e84a4a;
    box-shadow: 0 0 0 2px var(--bg-elevated);
    margin-left: 2px;
  }

  /* Make product card visually clickable */
  .product-card-mini { cursor: pointer; }

  /* Manage modal (dashboard product detail) */
  .manage-modal {
    max-width: 640px;
    text-align: left;
  }
  .manage-product-head {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .manage-product-img {
    width: 84px;
    height: 84px;
    background-size: cover;
    background-position: center;
    border-radius: 6px;
    flex-shrink: 0;
    background-color: var(--bg-elevated);
    border: 1px solid var(--border);
  }
  .manage-product-info {
    flex: 1;
    min-width: 0;
  }
  .manage-product-info h2 {
    font-family: var(--serif);
    font-size: 1.4rem;
    margin-bottom: 0.4rem;
    line-height: 1.2;
  }
  .manage-product-info .pricing {
    color: var(--fg-muted);
    font-size: 0.85rem;
    display: flex;
    gap: 1rem;
  }
  .manage-product-info .pricing .listed {
    color: var(--accent);
    font-weight: 600;
  }
  .manage-section-title {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .manage-edit-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    padding: 0.35rem 0.7rem;
    border-radius: 4px;
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.6rem;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .manage-edit-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .manage-edit-toggle.active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-elevated));
  }
  .manage-edit-toggle svg {
    flex-shrink: 0;
  }
  .manage-edit-panel {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 1.25rem;
    border-radius: 4px;
    margin: 1rem 0 1.5rem;
  }
  .manage-edit-panel .field { margin-bottom: 1rem; }
  .manage-edit-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .manage-reviews-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .manage-modal .reviews-list {
    max-height: 50vh;
    overflow-y: auto;
    padding-right: 0.5rem;
  }
  .manage-modal .review-card {
    background: var(--bg);
  }

  /* Reply form on dashboard */
  .reply-action {
    margin-top: 0.85rem;
    text-align: right;
  }
  .reply-form {
    margin-top: 0.85rem;
  }
  .reply-form textarea {
    width: 100%;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 0.6rem 0.7rem;
    font-family: var(--sans);
    font-size: 0.85rem;
    border-radius: 3px;
    resize: vertical;
    min-height: 48px;
  }
  .reply-form textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  .reply-form-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    justify-content: flex-end;
  }
  .btn-ghost {
    background: transparent !important;
    color: var(--fg-muted) !important;
    border: 1px solid var(--border) !important;
  }

  /* ---- VIP locks on theme/font tiles ---- */
  .theme-option.locked,
  .font-option.locked {
    position: relative;
    opacity: 0.7;
  }
  .theme-option.locked:hover,
  .font-option.locked:hover {
    opacity: 0.95;
    border-color: var(--accent-deep);
  }
  .theme-option.locked .theme-swatch,
  .font-option.locked .font-sample {
    filter: blur(0.5px);
  }
  .vip-badge {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.4rem;
    border-radius: 100px;
    margin-left: 0.5rem;
    vertical-align: middle;
    line-height: 1;
  }
  .vip-badge.sm {
    font-size: 0.55rem;
    padding: 0.1rem 0.35rem;
  }

  /* ---- Upgrade modal ---- */
  .upgrade-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow-y: auto;
    animation: fadeIn 0.25s ease;
  }
  .upgrade-modal {
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    padding: 2.5rem 2.25rem;
    max-width: 500px;
    width: 100%;
    text-align: center;
    border-radius: 6px;
    position: relative;
    margin: auto;
  }
  .upgrade-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: none;
    color: var(--fg-muted);
    font-size: 1.8rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s;
  }
  .upgrade-close:hover { color: var(--fg); }
  .upgrade-crown,
  .welcome-star {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }
  .upgrade-crown svg,
  .welcome-star svg {
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.4)) drop-shadow(0 0 8px rgba(212,175,55,0.22));
  }
  .welcome-star {
    margin-bottom: 1.5rem;
  }
  .upgrade-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .upgrade-modal h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.85rem;
    margin-bottom: 0.5rem;
    color: var(--fg);
    line-height: 1.2;
  }
  .upgrade-sub {
    color: var(--fg-muted);
    margin-bottom: 1.75rem;
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .upgrade-features {
    text-align: left;
    margin-bottom: 1.75rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
  .upgrade-feature {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.85rem;

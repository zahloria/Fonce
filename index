      const profit = +(markup - fee).toFixed(2);
      el.querySelector('#pv-listed').textContent = `$${listed.toFixed(2)}`;
      el.querySelector('#pv-profit').textContent = `$${profit.toFixed(2)}`;
    };
    el.querySelector('#ap-cost').oninput = updatePreview;
    el.querySelector('#ap-markup').oninput = updatePreview;

    // ------------------------------------------------------------

    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: 999px;
    border: 1px solid rgba(212,175,55,0.35);
    box-shadow:
      0 6px 24px -6px rgba(0,0,0,0.5),

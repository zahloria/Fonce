function runPhoneAnimation(el) {
  const ig = el.querySelector('#ig-screen');
  const ps = el.querySelector('#ps-screen');
  const pointer = el.querySelector('#tap-pointer');
  const link = el.querySelector('#ig-link-target');
  if (!ig || !ps || !pointer || !link) return;

  // Reset state
  ig.classList.remove('hide');
  ps.classList.remove('show');
  pointer.classList.remove('show', 'tapping');
  pointer.style.transform = 'translate(-50%, -50%) translate(-200px, 200px)';
  link.classList.remove('highlighted', 'tapped');

  // Sequence:
  // 1) wait, 2) pointer slides in, 3) hover/highlight link, 4) tap, 5) transition

  // 1. Pause to let user see IG
  setTimeout(() => {
    // Position pointer near the link
    const screenRect = el.querySelector('.phone-screen').getBoundingClientRect();
    const linkRect = link.getBoundingClientRect();
    const x = linkRect.left + linkRect.width / 2 - screenRect.left;
    const y = linkRect.top + linkRect.height / 2 - screenRect.top;

    // 2. Show pointer and animate to link
    pointer.classList.add('show');
    pointer.style.transform = `translate(${x}px, ${y}px)`;

    // 3. Highlight link
    setTimeout(() => {
      link.classList.add('highlighted');
    }, 850);

    // 4. Tap
    setTimeout(() => {
      pointer.classList.add('tapping');
      link.classList.add('tapped');
    }, 1300);

    // 5. Transition to showcase
    setTimeout(() => {
      ig.classList.add('hide');
      ps.classList.add('show');
      pointer.classList.remove('show', 'tapping');
    }, 1700);

  }, 1100);
}


      status.innerHTML = `<span class="spinner"></span>Fetching product details...`;
      fetchBtn.disabled = true;
      fetchBtn.textContent = 'Fetching...';

      // Clear the previous import badge (price stays locked)
      const costInput = el.querySelector('#ap-cost');
      const costBadge = el.querySelector('#ap-cost-badge');
      costBadge.innerHTML = '';

      let result = null;
      try {
        result = await fetchProductData(url);
      } catch (e) {
        console.warn('[Fonce] Fetch failed:', e);
      }

      fetchBtn.disabled = false;
      fetchBtn.textContent = 'Fetch';

      if (!result || (!result.title && !result.image && !result.price)) {
        status.className = 'fetch-status error';
        // Unlock price field for full manual entry path
        costInput.removeAttribute('readonly');
        costInput.classList.add('manual-entry');
        costInput.placeholder = 'Enter source price (one-time)';
        costBadge.innerHTML = '<span class="imported-badge warn">⚠ Auto-fetch failed &middot; type the price manually</span>';
        if (isAliExpressUrl(url)) {
          status.innerHTML = `
            <div class="aliex-helper">
              <strong>AliExpress blocks scrapers.</strong> Quick fill in 30 seconds:
              <ol>
                <li><a href="${escapeHtml(url)}" target="_blank" rel="noopener">Open product in AliExpress &rarr;</a></li>
                <li><strong>Right-click</strong> the main product image &rarr; <em>Copy image address</em> &rarr; paste in <strong>Image URL</strong> below</li>
                <li><strong>Copy</strong> the product title from the AliExpress page &rarr; paste in <strong>Product title</strong></li>
                <li><strong>Type</strong> the AliExpress price into <strong>Source price</strong></li>
              </ol>
            </div>
          `;
        } else {
          status.innerHTML = `Couldn't auto-fill from this URL. <strong>Some sites block fetchers.</strong> Enter details manually below — title, image URL, and source price are the only required fields.`;
        }
        return;
      }

      const filled = [];
      if (result.title && !el.querySelector('#ap-title').value) {
        el.querySelector('#ap-title').value = result.title.slice(0, 120);
        filled.push('title');
      }
      if (result.image && !imgInput.value) {
        imgInput.value = result.image;
        updateImagePreview();
        filled.push('image');
      }
      if (result.description && !el.querySelector('#ap-desc').value) {
        el.querySelector('#ap-desc').value = result.description.slice(0, 240);
        filled.push('description');
      }
      if (result.price && !costInput.value) {
        costInput.value = result.price.toFixed(2);
        costInput.setAttribute('readonly', 'readonly');
        costInput.classList.remove('manual-entry');
        costBadge.innerHTML = '<span class="imported-badge">Locked &middot; Source price from link</span>';
        updatePreview();
        filled.push('price');
      } else if (!result.price) {
        // Auto-fetch didn't return a price. Unlock the field so creator can enter
        // it manually ONCE during creation. Will lock permanently after the product is saved.
        costInput.removeAttribute('readonly');
        costInput.classList.add('manual-entry');
        costInput.placeholder = 'Enter source price (one-time)';
        costBadge.innerHTML = '<span class="imported-badge warn">⚠ Price not detected &middot; <a href="#" id="cost-help-link">type the price you see on the source page</a></span>';
        const helpLink = el.querySelector('#cost-help-link');
        if (helpLink) {
          helpLink.onclick = (ev) => { ev.preventDefault(); costInput.focus(); };
        }
      }

      console.log('[Fonce] Auto-filled:', filled);

      // Render variants if AliExpress returned them
      const variantsPanel = el.querySelector('#ap-variants');
      const variantsList = el.querySelector('#ap-variants-list');
      const variantsCount = el.querySelector('#ap-variants-count');
      if (result.variants && result.variants.length > 0) {
        variantsPanel.style.display = 'block';
        variantsCount.textContent = result.variants.length + ' variant' + (result.variants.length === 1 ? '' : 's') + ' — pick which one you\'re selling';
        variantsList.innerHTML = result.variants.map((v, i) => `
          <button type="button" class="variant-chip" data-sku="${escapeHtml(v.sku)}" data-label="${escapeHtml(v.label)}" data-price="${v.price || ''}">
            <span class="variant-chip-label">${escapeHtml(v.label)}</span>
            ${v.price ? `<span class="variant-chip-price">$${v.price.toFixed(2)}</span>` : ''}
          </button>
        `).join('');
        variantsList.querySelectorAll('.variant-chip').forEach(chip => {
          chip.onclick = () => {
            variantsList.querySelectorAll('.variant-chip').forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            // Append variant label to the title
            const titleInput = el.querySelector('#ap-title');
            const baseTitle = titleInput.value.split(' — ')[0]; // strip prior variant
            titleInput.value = baseTitle + ' — ' + chip.dataset.label;
            // Update price to this variant's price (programmatic write works on readonly inputs)
            const variantPrice = parseFloat(chip.dataset.price);
            if (variantPrice && variantPrice > 0) {
              el.querySelector('#ap-cost').value = variantPrice.toFixed(2);
              updatePreview();
            }
            // Store SKU in a hidden attribute on the form
            el.dataset.selectedSku = chip.dataset.sku;
            el.dataset.selectedVariantLabel = chip.dataset.label;
          };
        });
      } else {
        variantsPanel.style.display = 'none';
      }

      if (filled.length === 0) {
        status.className = 'fetch-status';
        status.textContent = 'Page found but fields already filled. Clear them to refetch.';
      } else {
        const missing = [];
        if (!filled.includes('title')) missing.push('title');
        if (!filled.includes('image')) missing.push('image');
        if (!filled.includes('price')) missing.push('price');
        status.className = 'fetch-status success';
        let msg = `&#10003; <strong>Got ${filled.join(', ')}</strong>`;
        if (missing.length > 0) {
          msg += ` &middot; <span style="color:var(--fg-muted)">please add ${missing.join(' & ')} manually below</span>`;
        }
        status.innerHTML = msg;
      }
    };

    fetchBtn.onclick = doFetch;
    sourceInput.addEventListener('blur', () => {
      const url = sourceInput.value.trim();
      const titleFilled = !!el.querySelector('#ap-title').value;
      if (url && /^https?:\/\//i.test(url) && !titleFilled) {
        doFetch();
      }
    });

    // Live source tier badge — show as soon as a URL is pasted
    const tierPreview = el.querySelector('#ap-tier-preview');
    const updateTierBadge = () => {
      const url = sourceInput.value.trim();
      if (!url || !/^https?:\/\//i.test(url)) {
        tierPreview.style.display = 'none';
        return;
      }
      const tier = detectSourceTier(url);
      tierPreview.style.display = 'flex';
      tierPreview.className = 'source-tier-preview tier-' + tier.key;
      tierPreview.innerHTML = `
        <div class="tier-icon">${tier.key === 'premium' ? '★' : (tier.key === 'verified' ? '✓' : '·')}</div>
        <div class="tier-text">
          <div class="tier-label">${tier.label}</div>
          <div class="tier-sub">${tier.badge}</div>
        </div>
        ${tier.key !== 'premium' ? `<a href="#" class="tier-upgrade-link" id="tier-upgrade-${Date.now()}">Upgrade your source &rarr;</a>` : ''}
      `;
      // Wire the upgrade link to show sourcing guide
      const upgradeLink = tierPreview.querySelector('.tier-upgrade-link');
      if (upgradeLink) upgradeLink.onclick = (e) => { e.preventDefault(); showSourcingGuide(); };
    };
    sourceInput.addEventListener('input', () => {
      updateTierBadge();
      const url = sourceInput.value.trim();
      if (isAliExpressUrl(url) && !status.classList.contains('success')) {
        status.className = 'fetch-status notice';
        status.innerHTML = `<strong>Heads up:</strong> AliExpress blocks most auto-fill tools. Try Fetch &mdash; if it fails, you'll get a 4-step quick-paste guide.`;
      }
    });
    // Run once in case the URL is pre-filled (e.g. from extension import)
    setTimeout(updateTierBadge, 50);

    // "Where should I source from?" guide
    el.querySelector('#ap-sources-guide').onclick = (e) => {
      e.preventDefault();
      showSourcingGuide();
    };

    el.querySelector('#ap-go').onclick = () => {
      const title = el.querySelector('#ap-title').value.trim();
      const image = el.querySelector('#ap-image').value.trim();
      const sourceUrl = el.querySelector('#ap-source').value.trim();
      const sourcePrice = el.querySelector('#ap-cost').value;
      const markup = el.querySelector('#ap-markup').value;
      const description = el.querySelector('#ap-desc').value.trim();
      if (!sourceUrl || !/^https?:\/\//i.test(sourceUrl)) {
        el.querySelector('#err').innerHTML = `<div class="error">Source URL is required. Paste a product link and click <strong>Fetch</strong>.</div>`;
        return;
      }
      if (!sourcePrice || +sourcePrice <= 0) {
        el.querySelector('#err').innerHTML = `<div class="error">Source price is required. Click <strong>Fetch</strong> — if auto-fill doesn't catch it, type the price you see on the source page.</div>`;
        return;
      }
      if (!title) {
        el.querySelector('#err').innerHTML = `<div class="error">Title is required.</div>`;
        return;
      }
      if (!markup || +markup < 0) {
        el.querySelector('#err').innerHTML = `<div class="error">Set your markup.</div>`;
        return;
      }
      addProduct({ title, image, sourceUrl, sourcePrice, markup, description, variantSku: el.dataset.selectedSku, variantLabel: el.dataset.selectedVariantLabel });
      toast('Product added.');
      navigate('dashboard');
    };
  }, 0);

  return el;
}

function viewShowcase() {
  const username = state.showcaseUser;
  const user = state.users[username];
  if (!user) {
    return $(`<div class="form-page"><h1>Showcase not found</h1><p class="sub">No user @${escapeHtml(username || '')} on Fonce.</p><button class="btn" onclick="navigate('landing')">Home</button></div>`);
  }
  trackShowcaseVisit();
  const initial = user.username.charAt(0).toUpperCase();
  const visibleProducts = user.products.filter(p => !p.paused && !p.archived);
  let body = '';

  // Decide what to render in the price slot based on user preference
  const priceDisplay = user.priceDisplay || 'price';
  const renderPriceSlot = (p) => {
    if (priceDisplay === 'shop') {
      return `<button class="shop-now-btn" onclick="event.stopPropagation();navigate('productDetail',{showcaseUser:'${user.username}',selectedProduct:'${p.id}'})">Shop now</button>`;
    }
    if (priceDisplay === 'cart') {
      return `<div class="showcase-price-cart-row">
        <div class="price">$${p.listedPrice.toFixed(2)}</div>
        <button class="showcase-cart-btn" onclick="event.stopPropagation();navigate('productDetail',{showcaseUser:'${user.username}',selectedProduct:'${p.id}'})" aria-label="Shop ${escapeHtml(p.title)}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 3 H5 L7 16 H19 L21 8 H6"/>
            <circle cx="9" cy="20" r="1.4"/>
            <circle cx="17" cy="20" r="1.4"/>
          </svg>
        </button>
      </div>`;
    }
    return `<div class="price">$${p.listedPrice.toFixed(2)}</div>`;
  };

  if (visibleProducts.length === 0) {
    body = `<div class="empty-state"><h3>No products yet.</h3><p>This creator hasn't added anything to their showcase.</p></div>`;
  } else if (user.template === 'grid') {
    body = `
      <div class="grid-template">
        ${visibleProducts.map(p => `
          <div class="product-card" onclick="navigate('productDetail',{showcaseUser:'${user.username}',selectedProduct:'${p.id}'})">
            <div class="img" style="background-image:url('${escapeHtml(p.image || fallbackImg(p.id))}')"></div>
            <div class="title">${escapeHtml(p.title)}</div>
            ${renderPriceSlot(p)}
          </div>
        `).join('')}
      </div>
    `;
  } else if (user.template === 'editorial') {
    body = `
      <div class="editorial-template">
        ${visibleProducts.map((p, i) => `
          <div class="ed-item" onclick="navigate('productDetail',{showcaseUser:'${user.username}',selectedProduct:'${p.id}'})">
            <div class="img" style="background-image:url('${escapeHtml(p.image || fallbackImg(p.id))}')"></div>
            <div class="ed-content">
              <div class="num">${String(i+1).padStart(2,'0')}</div>
              <h3>${escapeHtml(p.title)}</h3>
              ${renderPriceSlot(p)}
              <p style="color:var(--fg-muted);margin-bottom:1.5rem">${escapeHtml(p.description || '')}</p>
              <button class="btn">View &rarr;</button>
            </div>
          </div>
        `).join('')}
      </div>
    `;
  } else {
    body = `
      <div class="minimal-template">
        ${visibleProducts.map(p => `
          <div class="min-item" onclick="navigate('productDetail',{showcaseUser:'${user.username}',selectedProduct:'${p.id}'})">
            <div class="img" style="background-image:url('${escapeHtml(p.image || fallbackImg(p.id))}')"></div>
            <div class="info">
              <h4>${escapeHtml(p.title)}</h4>
              <p>${escapeHtml(p.description || '')}</p>
            </div>
            ${renderPriceSlot(p)}
          </div>
        `).join('')}
      </div>
    `;
  }

  const reviews = getReviews(user.username);
  const avgRating = getAverageRating(user.username);
  const eligibility = canReview(user.username);
  const isOwner = state.currentUser === user.username;

  const reviewsHtml = `
    <section class="reviews-section">
      <div class="reviews-header">
        <h2>Reviews</h2>
        ${reviews.length > 0 ? `
          <div class="reviews-summary">
            ${renderStarRating(avgRating, { size: 18 })}
            <span class="reviews-rating">${avgRating.toFixed(1)}</span>
            <span class="reviews-count">&middot; ${reviews.length} ${reviews.length === 1 ? 'review' : 'reviews'}</span>
          </div>
        ` : ''}
      </div>

      ${reviews.length === 0 ? `
        <div class="reviews-empty">No reviews yet${eligibility.ok ? ' &mdash; be the first.' : '.'}</div>
      ` : `
        <div class="reviews-list">
          ${reviews.map(r => {
            const product = user.products.find(p => p.id === r.productId);
            const productName = product ? product.title : null;
            return `
              <div class="review-card">
                <div class="review-head">
                  ${userAvatar(r.reviewer, 'review-avatar')}
                  <div class="review-meta">
                    <div class="review-name">@${escapeHtml(r.reviewer)}</div>
                    <div class="review-time">${timeAgo(r.createdAt)}${productName ? ` &middot; on <span class="review-product">${escapeHtml(productName)}</span>` : ''}</div>
                  </div>
                  ${renderStarRating(r.rating, { size: 14 })}
                </div>
                ${r.comment ? `<p class="review-comment">${escapeHtml(r.comment)}</p>` : ''}
                ${r.image ? `<div class="review-image" style="background-image:url('${escapeHtml(r.image).slice(0,500)}')"></div>` : ''}
                ${r.reply ? `
                  <div class="review-reply">
                    <div class="review-reply-head">
                      ${userAvatar(user.username, 'review-avatar review-avatar-creator')}
                      <div class="review-meta">
                        <div class="review-name">@${escapeHtml(user.username)} <span class="creator-tag">creator</span></div>
                        <div class="review-time">${timeAgo(r.reply.createdAt)}</div>
                      </div>
                    </div>
                    <p class="review-comment">${escapeHtml(r.reply.text)}</p>
                  </div>
                ` : ''}
              </div>
            `;
          }).join('')}
        </div>
      `}

      ${!isOwner ? `
        <div class="review-cta">
          ${eligibility.ok ? `
            <button class="btn" id="leave-review-btn">Leave a review</button>
          ` : eligibility.reason ? `
            <div class="review-cta-msg">${escapeHtml(eligibility.reason)}${eligibility.signin ? ` <a onclick="navigate('login')">Sign in</a>` : ''}</div>
          ` : ''}
        </div>
      ` : ''}
    </section>
  `;

  const el = $(`
    <div class="showcase">
      <div class="container">
        <div class="showcase-header">
          ${userAvatar(user.username, 'avatar avatar-large')}
          <h1>@${escapeHtml(user.username)}</h1>
          <p class="handle">${escapeHtml(user.tagline || 'curated picks')}</p>
        </div>
        ${body}
        ${reviewsHtml}
      </div>
    </div>
  `);

  setTimeout(() => {
    const btn = el.querySelector('#leave-review-btn');
    if (btn) btn.onclick = () => showReviewModal(user.username);
  }, 0);

  return el;

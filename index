  }
  .sg-bottom {
    margin-top: 1rem;
    padding: 1rem 1.2rem;
    background: var(--bg-elevated);
    border-radius: 4px;
    border-left: 3px solid var(--accent);
  }
  .sg-bottom p { color: var(--fg); font-size: 0.88rem; line-height: 1.6; }
  .sg-bottom strong { color: var(--accent-bright); }

  /* Variant picker (AliExpress imports) */
  .variant-picker {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    background: var(--bg-elevated);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
    border-radius: 4px;
  }
  .variant-picker-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.7rem;
  }
  .variant-picker-title {
    font-family: var(--serif);
    font-size: 0.95rem;
    color: var(--fg);
    font-weight: 500;
  }
  .variant-picker-sub {
    font-size: 0.72rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .variant-picker-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .variant-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    cursor: pointer;
    font-family: var(--sans);
    font-size: 0.82rem;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;

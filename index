  .upload-btn-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
    color: var(--accent);
    padding: 0 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    font-family: var(--sans);
    font-size: 0.78rem;

function getPurchasedProductsFrom(influencerUsername) {
  if (!state.currentUser) return [];
  const buyer = state.users[state.currentUser];
  if (!buyer) return [];
  const orders = state.orders.filter(o =>
    o.influencer === influencerUsername && o.buyerEmail === buyer.email
  );

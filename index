  }
  @keyframes liveTagPulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  /* Textured theme tile — show texture preview in swatch */
  .theme-option.textured .theme-swatch {
    background-blend-mode: overlay;
  }

  /* Live mode toggle in dashboard */
  .live-mode-block {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1rem 1.25rem;
    border-radius: 4px;
    margin-top: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .live-mode-block.locked {
    opacity: 0.85;
  }
  .live-mode-info {
    flex: 1;
    min-width: 0;
  }
  .live-mode-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--fg);
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .live-mode-sub {
    color: var(--fg-muted);
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .live-switch {
    position: relative;
    display: inline-block;
    width: 48px;
    height: 26px;
    flex-shrink: 0;
  }
  .live-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .live-switch-slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .live-switch-slider::before {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    left: 2px;
    top: 2px;
    background: var(--fg-muted);
    border-radius: 50%;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .live-switch input:checked + .live-switch-slider {
    background: var(--accent);
    border-color: var(--accent);
  }
  .live-switch input:checked + .live-switch-slider::before {
    transform: translateX(22px);
    background: var(--bg);
  }

  /* Image input — URL field + inline upload button (side by side) */
  .image-input-row {
    display: flex;
    gap: 0.5rem;

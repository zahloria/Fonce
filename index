        <h4>${escapeHtml(item.product.title)}</h4>
        <p style="color:var(--fg-muted);font-size:0.85rem">From @${escapeHtml(item.influencerUsername)}</p>
      </div>
      <div class="price">$${item.product.listedPrice.toFixed(2)}</div>
    </div>
  `).join('');

  const el = $(`
    <div class="checkout">
      <a class="back-link" onclick="navigate('cart')">&larr; Back to bag</a>
      <h1>Checkout</h1>

      ${itemsHtml}

      <div class="cart-total" style="margin-bottom:2rem">
        <div class="cart-total-row">
          <span>Subtotal</span>
          <span class="cart-total-amount">$${total.toFixed(2)}</span>
        </div>
        ${rewardsApplied > 0 ? `
          <div class="cart-total-row" style="color:var(--accent)">
            <span>Fonce Rewards applied</span>
            <span>&minus;$${rewardsApplied.toFixed(2)}</span>
          </div>
        ` : ''}
        <div class="cart-total-row final-row">
          <span><strong>Total</strong></span>
          <span class="cart-total-amount">$${finalTotal.toFixed(2)}</span>
        </div>
        ${projectedEarn > 0 ? `
          <p class="cart-fee-note" style="color:var(--accent);margin-top:0.5rem">
            You'll earn <strong>$${projectedEarn.toFixed(2)}</strong> in Fonce Rewards on this order.
          </p>
        ` : ''}
      </div>

      <div id="err"></div>

      <div class="field">
        <label>Email (for shipping labels)</label>
        <input id="co-email" type="email" value="${escapeHtml(buyer.email)}" />
      </div>
      <div class="field">
        <label>Shipping address</label>
        <textarea id="co-addr" rows="3" placeholder="Street, City, State, ZIP, Country"></textarea>
      </div>
      <div class="field">
        <label>Card number (demo &mdash; any 16 digits)</label>
        <input id="co-card" placeholder="4242 4242 4242 4242" />
      </div>

      <button class="btn btn-primary btn-block" id="co-go">Place order &middot; $${finalTotal.toFixed(2)}</button>
      <p style="color:var(--fg-dim);font-size:0.8rem;text-align:center;margin-top:1rem">This is a demo. No real payment will be processed.</p>
    </div>
  `);

  setTimeout(() => {
    el.querySelector('#co-go').onclick = () => {
      const email = el.querySelector('#co-email').value.trim();
      const addr = el.querySelector('#co-addr').value.trim();
      const card = el.querySelector('#co-card').value.trim();
      if (!email || !addr || card.replace(/\s/g, '').length < 12) {
        el.querySelector('#err').innerHTML = `<div class="error">Fill in email, address, and a (demo) card number.</div>`;
        return;
      }
      placeCartOrders(email, addr, rewardsApplied);
      navigate('confirmation');
    };
  }, 0);

  return el;
}

load();


function escapeHtml(s) {
  if (s == null) return '';
  return String(s).replace(/[&<>"']/g, c => ({
    '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
  }[c]));
}
function $(html) {
  const t = document.createElement('template');
  t.innerHTML = html.trim();
  return t.content.firstChild;
}
function toast(msg) {
  const el = $(`<div class="toast">${escapeHtml(msg)}</div>`);
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 2400);
}
function toastWithUndo(msg, onUndo, durationMs = 5000) {
  // Remove any existing toast-undo first
  document.querySelectorAll('.toast-undo').forEach(t => t.remove());
  const el = $(`
    <div class="toast toast-undo">
      <span class="toast-msg">${escapeHtml(msg)}</span>
      <button class="toast-undo-btn">Undo</button>
    </div>
  `);
  document.body.appendChild(el);
  const dismiss = () => el.remove();
  const timeout = setTimeout(dismiss, durationMs);
  el.querySelector('.toast-undo-btn').onclick = () => {
    clearTimeout(timeout);
    dismiss();
    onUndo();
  };
}

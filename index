  .stat .label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.5rem;
  }
  .stat .val {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 600;
    color: var(--accent);

  /* Sourcing guide modal */
  .sourcing-guide-modal {
    max-width: 720px;
    max-height: 88vh;
    overflow-y: auto;
  }
  .sg-hero {
    padding-bottom: 1.2rem;
    margin-bottom: 1.5rem;

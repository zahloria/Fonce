    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .insight {
    background: var(--bg-elevated);
    padding: 1.5rem;
  }
  .insight .label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 0.5rem;
  }
  .insight .val {

  }
  .sg-hero h2 {
    font-family: var(--serif);
    font-size: 1.6rem;
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }
  .sg-lead { color: var(--fg-muted); font-size: 0.92rem; line-height: 1.55; }

  .sg-tier-section {
    margin-bottom: 1.75rem;
    padding: 1.25rem;
    border-radius: 6px;
    border: 1px solid;
  }
  .sg-tier-section.tier-premium {

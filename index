    cursor: pointer;
    border-radius: 50%;
  }
  .dash-avatar-wrap .avatar.dash-avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    color: var(--bg);
    font-size: 3rem;
    font-weight: 600;
    margin: 0;

function viewCart() {
  if (!state.currentUser) { navigate('login'); return $(`<div></div>`); }
  const cart = getCart();
  const total = getCartTotal();

  if (cart.length === 0) {
    return $(`
      <div class="cart-page">
        <div class="container">
          <h1>Your bag</h1>
          <div class="empty-state">
            <h3>Nothing in your bag yet.</h3>
            <p>Browse creator showcases to add products.</p>
            <button class="btn" onclick="navigate('landing')" style="margin-top:1.5rem">Browse Fonce</button>
          </div>
        </div>
      </div>
    `);
  }

  // Group items by influencer for cleaner display
  const byInfluencer = {};
  cart.forEach(item => {
    if (!byInfluencer[item.influencerUsername]) byInfluencer[item.influencerUsername] = [];
    byInfluencer[item.influencerUsername].push(item);
  });
  const creatorCount = Object.keys(byInfluencer).length;

  const cartHtml = Object.keys(byInfluencer).map(username => {
    const items = byInfluencer[username];
    return `
      <div class="cart-group">
        <div class="cart-group-header">
          <span class="cart-group-from">From</span>
          <a onclick="navigate('showcase',{showcaseUser:'${username}'})">@${escapeHtml(username)}</a>
        </div>
        ${items.map(item => `
          <div class="cart-item">
            <div class="img" style="background-image:url('${escapeHtml(item.product.image || fallbackImg(item.product.id))}')"></div>
            <div class="info">
              <h4>${escapeHtml(item.product.title)}</h4>
              <div class="cart-item-price">$${item.product.listedPrice.toFixed(2)}</div>
            </div>
            <button class="cart-remove" data-product-id="${item.product.id}" data-influencer="${item.influencerUsername}" aria-label="Remove">&times;</button>
          </div>
        `).join('')}
      </div>
    `;
  }).join('');

  const buyerForCart = state.users[state.currentUser];
  const rewardsBalance = getRewardsBalance(buyerForCart);
  const maxRewardsApplicable = Math.min(rewardsBalance, total);
  const rewardsAppliedDefault = (buyerForCart && buyerForCart._cartRewardsToggle) ? maxRewardsApplicable : 0;
  const cashAfterRewards = +(total - rewardsAppliedDefault).toFixed(2);

  const el = $(`
    <div class="cart-page">
      <div class="container">
        <h1>Your bag</h1>
        <p class="cart-sub">${cart.length} item${cart.length > 1 ? 's' : ''} from ${creatorCount} creator${creatorCount > 1 ? 's' : ''}.</p>

        <div class="cart-list">${cartHtml}</div>

        <div class="cart-total">
          <div class="cart-total-row">
            <span>Subtotal</span>
            <span class="cart-total-amount">$${total.toFixed(2)}</span>
          </div>
          ${rewardsBalance > 0 ? `
            <div class="rewards-apply-block">
              <label class="rewards-apply-row">
                <input type="checkbox" id="rewards-toggle" ${rewardsAppliedDefault > 0 ? 'checked' : ''}>
                <div class="rewards-apply-info">
                  <div class="rewards-apply-title">Apply Fonce Rewards</div>
                  <div class="rewards-apply-sub">$${rewardsBalance.toFixed(2)} available &middot; up to $${maxRewardsApplicable.toFixed(2)} usable</div>
                </div>
                <div class="rewards-apply-amount" id="rewards-amt">${rewardsAppliedDefault > 0 ? '&minus;$' + rewardsAppliedDefault.toFixed(2) : ''}</div>
              </label>
            </div>
            <div class="cart-total-row final-row">
              <span><strong>Total</strong></span>
              <span class="cart-total-amount" id="cart-final-total">$${cashAfterRewards.toFixed(2)}</span>
            </div>
          ` : ''}
          <p class="cart-fee-note">Each item ships separately from its source. Estimated delivery 7&ndash;14 days.${buyerForCart && buyerForCart.isVip ? ` <span style="color:var(--accent)">VIPs earn 5% back in Fonce Rewards on every order.</span>` : ''}</p>
        </div>

        <button class="btn btn-primary btn-block" id="cart-checkout-btn" onclick="navigate('cartCheckout')">Checkout &middot; $${cashAfterRewards.toFixed(2)}</button>
      </div>
    </div>
  `);

  setTimeout(() => {
    el.querySelectorAll('.cart-remove').forEach(btn => {
      btn.onclick = () => {
        removeFromCart(btn.dataset.productId, btn.dataset.influencer);
        toast('Removed from bag.');
        render();
      };
    });
    const rewardsToggle = el.querySelector('#rewards-toggle');
    if (rewardsToggle) {
      rewardsToggle.onchange = () => {
        const applying = rewardsToggle.checked ? maxRewardsApplicable : 0;
        const newTotal = +(total - applying).toFixed(2);
        const amtEl = el.querySelector('#rewards-amt');
        const finalEl = el.querySelector('#cart-final-total');
        const btn = el.querySelector('#cart-checkout-btn');
        if (amtEl) amtEl.innerHTML = applying > 0 ? '&minus;$' + applying.toFixed(2) : '';
        if (finalEl) finalEl.textContent = '$' + newTotal.toFixed(2);
        if (btn) btn.innerHTML = 'Checkout &middot; $' + newTotal.toFixed(2);
        // Persist user preference for this session
        if (buyerForCart) {
          buyerForCart._cartRewardsToggle = rewardsToggle.checked;
          save();
        }
      };
    }
  }, 0);

  return el;
}

function viewCartCheckout() {
  if (!state.currentUser) { navigate('login'); return $(`<div></div>`); }
  const cart = getCart();
  if (cart.length === 0) { navigate('cart'); return $(`<div></div>`); }
  const total = getCartTotal();
  const buyer = state.users[state.currentUser];
  const rewardsBalance = getRewardsBalance(buyer);
  const isApplying = buyer && buyer._cartRewardsToggle && rewardsBalance > 0;
  const rewardsApplied = isApplying ? Math.min(rewardsBalance, total) : 0;
  const finalTotal = +(total - rewardsApplied).toFixed(2);
  const projectedEarn = buyer && buyer.isVip ? +(total * REWARDS_EARN_RATE).toFixed(2) : 0;

  const itemsHtml = cart.map(item => `
    <div class="order-summary">
      <div class="img" style="background-image:url('${escapeHtml(item.product.image || fallbackImg(item.product.id))}')"></div>

    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .dash-avatar-wrap:hover .avatar.dash-avatar {
    transform: scale(1.02);
    border-color: rgba(212,175,55,0.7);

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>FONCÉ — Showcase what you sell.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400..900,0..100&family=DM+Sans:opsz,wght@9..40,400..700&family=Playfair+Display:wght@400..900&family=Inter:wght@300..700&family=Space+Grotesk:wght@300..700&family=Cormorant+Garamond:wght@300..700&family=Manrope:wght@300..700&family=Instrument+Serif&family=Bricolage+Grotesque:wght@300..800&family=Montserrat:wght@300..800&family=Bodoni+Moda:opsz,wght@6..96,400..900&family=Outfit:wght@300..700&family=Italiana&family=Marcellus&family=Syne:wght@400..800&family=DM+Serif+Display&display=swap" rel="stylesheet">
<style>
  /* ============================================
     THEME
     ============================================ */
  :root {
    --bg: #0a0a0a;
    --bg-elevated: #161616;
    --bg-soft: #1f1f1f;
    --border: rgba(212,175,55,0.18);
    --border-strong: rgba(212,175,55,0.45);
    --fg: #f5efe4;
    --fg-muted: rgba(245,239,228,0.65);
    --fg-dim: rgba(245,239,228,0.4);
    --accent: #d4af37;
    --accent-bright: #ecc960;
    --accent-deep: #9a7d24;
    --danger: #ff6b6b;
    --success: #6dd391;
    --max: 1200px;
    --serif: 'Fraunces', Georgia, serif;
    --sans: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--page-bg, linear-gradient(180deg,
      #0a0a14 0%,
      #1a1430 18%,
      #3d1f47 36%,
      #722844 52%,
      #b03f48 66%,
      #de6e3a 80%,
      #e8a04a 92%,
      #1a1410 100%
    ));
    background-attachment: fixed;
    color: var(--fg);
    font-family: var(--sans);
    font-weight: 500;
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.5) 100%),
      linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 30%, transparent 70%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
    z-index: 0;
  }
  img { max-width: 100%; display: block; }
  button, input, select, textarea { font: inherit; color: inherit; }
  a { color: var(--accent); text-decoration: none; transition: opacity 0.2s; cursor: pointer; }
  a:hover { opacity: 0.75; }

  .container { max-width: var(--max); margin: 0 auto; padding: 0 1.5rem; position: relative; z-index: 1; }
  .wrap { position: relative; z-index: 1; }

  header {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    background: rgba(10,10,10,0.7);
    backdrop-filter: blur(24px) saturate(140%);
    z-index: 100;
  }
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .brand:hover { opacity: 0.85; }
  .brand-star {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.4)) drop-shadow(0 0 6px rgba(212,175,55,0.18));
  }
  .hero-mark {
    display: inline-block;
    position: relative;
    margin-left: 0.04em;
    vertical-align: baseline;
    line-height: 1;
  }
  .hero-star {
    display: inline-block;
    width: 0.22em;
    height: 0.22em;
    vertical-align: -0.02em;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.4)) drop-shadow(0 0 4px rgba(212,175,55,0.2));
  }
  .hero-c {
    position: absolute;
    bottom: 8%;
    left: 92%;
    font-size: 0.11em;
    color: var(--accent);
    font-family: var(--sans);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
    white-space: nowrap;
  }
  .brand-text {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    font-variation-settings: "opsz" 144, "SOFT" 50;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.55),
      0 2px 4px rgba(0, 0, 0, 0.25);
  }
  .nav-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .nav-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .cart-btn {
    position: relative;
    background: transparent;
    border: 1px solid transparent;
    padding: 0.5rem 0.65rem;
    color: var(--fg);
    cursor: pointer;
    border-radius: 100px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  /* Cart star — drops in on add, flies out on click */
  .cart-btn .cart-star {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .cart-btn.has-items .cart-star {
    opacity: 1;
  }
  .cart-btn.dropping .cart-star {
    animation: cartStarDrop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  .cart-btn.flying .cart-star {
    animation: cartStarFly 0.4s ease-in forwards;
  }
  @keyframes cartStarDrop {
    0% {
      opacity: 0;
      transform: translateY(-14px) scale(0.3) rotate(-30deg);
    }
    50% {
      opacity: 1;
      transform: translateY(2px) scale(1.2) rotate(20deg);
    }
    75% {
      opacity: 1;
      transform: translateY(-1px) scale(0.95) rotate(-5deg);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1) rotate(0deg);
    }
  }
  @keyframes cartStarFly {
    0% {
      opacity: 1;
      transform: translateY(0) scale(1) rotate(0deg);
    }
    30% {
      opacity: 1;
      transform: translateY(-3px) scale(1.15) rotate(-8deg);
    }
    100% {
      opacity: 0;
      transform: translateY(-22px) scale(0.4) rotate(45deg);
    }
  }
  .cart-badge {
    position: absolute;
    top: -2px;
    right: -2px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 100px;
    padding: 0.1rem 0.45rem;
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1.4;
    min-width: 18px;
    text-align: center;
  }

  /* ---- Cart page ---- */
  .cart-page {
    padding: 4rem 0 6rem;
  }
  .cart-page .container {
    max-width: 760px;
  }
  .cart-page h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }
  .cart-sub {
    color: var(--fg-muted);
    margin-bottom: 2.5rem;
  }
  .cart-group {
    margin-bottom: 2rem;
  }
  .cart-group-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .cart-group-from {
    color: var(--fg-muted);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .cart-group-header a {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--accent);
    cursor: pointer;
  }
  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto auto;
    gap: 1.25rem;
    align-items: center;
    padding: 1rem 0;
  }
  .cart-item .img {
    width: 80px;
    height: 80px;
    background: var(--bg-elevated);
    background-size: cover;
    background-position: center;
    border: 1px solid var(--border);
  }
  .cart-item .info h4 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  .cart-item-price {
    font-family: var(--serif);
    color: var(--accent);
    font-size: 1.15rem;
  }
  .cart-remove {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    transition: all 0.2s;
  }
  .cart-remove:hover {
    border-color: var(--danger);
    color: var(--danger);
  }
  .cart-total {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 4px;
  }
  .cart-total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--serif);
    font-size: 1.25rem;
  }
  .cart-total-amount {
    color: var(--accent);
    font-weight: 600;
    font-size: 1.5rem;
  }
  .cart-fee-note {
    color: var(--fg-dim);
    font-size: 0.8rem;
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* ---- Detail page action buttons ---- */
  .detail-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .cart-item {
      grid-template-columns: 64px 1fr auto;
      gap: 0.85rem;
    }
    .cart-item .img { width: 64px; height: 64px; }
    .cart-item-price { grid-column: 2; }
    .cart-remove { grid-row: 1; grid-column: 3; align-self: start; }
  }
  .menu-toggle {
    background: transparent;
    border: 1px solid transparent;
    cursor: pointer;
    padding: 0.5rem 0.6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    align-items: center;
    border-radius: 2px;
    transition: all 0.2s;
  }
  .menu-toggle:hover { border-color: var(--border); }
  .menu-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--fg);
    transition: all 0.3s;
  }
  .menu-toggle:hover span { background: var(--accent); }

  .drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(6px);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .drawer-overlay.open { opacity: 1; pointer-events: auto; }

  .drawer {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 400px;
    max-width: 92vw;
    background: var(--bg-elevated);
    border-right: 1px solid var(--border);
    z-index: 201;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    overflow-y: auto;
    padding: 2rem 2rem 3rem;
  }
  .drawer.open { transform: translateX(0); }
  .drawer-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--fg-muted);
    font-size: 1.75rem;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    transition: color 0.2s;
  }
  .drawer-close:hover { color: var(--accent); }
  .drawer-eyebrow {
    color: var(--accent);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .drawer h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }
  .drawer .drawer-sub {
    color: var(--fg-muted);
    font-size: 0.875rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .source-group { margin-bottom: 2rem; }
  .source-group h3 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .source-link {
    display: block;
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    margin-bottom: 0.5rem;
    border-radius: 2px;
    transition: all 0.2s;
    text-decoration: none;
  }
  .source-link:hover {
    border-color: var(--accent);
    transform: translateX(4px);
    opacity: 1;
  }
  .source-link .name {
    color: var(--fg);
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 500;
    margin-bottom: 0.15rem;
    display: block;
  }
  .source-link .desc {
    color: var(--fg-muted);
    font-size: 0.78rem;
    display: block;
  }
  .drawer-foot {
    color: var(--fg-dim);
    font-size: 0.8rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    line-height: 1.5;
    font-style: italic;
    font-family: var(--serif);
  }

  /* ============================================
     PARTNERSHIPS PAGE
     ============================================ */
  .partnerships-page {
    padding: 5rem 0 6rem;
  }
  .partnerships-page .container {
    max-width: 800px;
  }
  .partner-eyebrow {
    color: var(--accent);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .partnerships-page h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    font-variation-settings: "opsz" 144;
  }
  .partner-lede {
    color: var(--fg-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 4rem;
    max-width: 640px;
  }
  .partner-types {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 5rem;
  }
  .partner-type {
    background: var(--bg-elevated);
    padding: 1.75rem 1.5rem;
  }
  .partner-type h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .partner-type p {
    color: var(--fg-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .partnerships-page h2 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 2rem;
    margin-bottom: 0.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .partner-form-sub {
    color: var(--fg-muted);
    font-size: 0.875rem;
    margin: 1rem 0 2rem;
  }
  .partner-direct {
    text-align: center;
    color: var(--fg-muted);
    font-size: 0.9rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .partner-direct a {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.05rem;
  }
  @media (max-width: 768px) {
    .partner-types { grid-template-columns: 1fr; }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--fg);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0;
    cursor: pointer;
    border-radius: 100px;
    transition: all 0.2s;
    font-family: var(--sans);
  }
  .btn:hover { border-color: var(--accent); color: var(--accent); }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
    font-weight: 600;
  }
  .btn-primary:hover { background: var(--accent-bright); border-color: var(--accent-bright); color: var(--bg); }
  .btn-ghost { border-color: transparent; }
  .btn-sm { padding: 0.45rem 1rem; font-size: 0.85rem; }
  .btn-block { width: 100%; }
  .btn-danger:hover { border-color: var(--danger); color: var(--danger); }

  .hero {
    padding: 8rem 0 6rem;
    text-align: center;
  }
  .hero .eyebrow {
    color: var(--accent);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    text-shadow: 0 4px 40px rgba(0,0,0,0.5);
  }
  .hero h1 em {
    font-style: italic;
    color: var(--accent);
    font-weight: 600;
  }
  .hero .lede {
    color: var(--fg);
    opacity: 0.9;
    font-size: 1.15rem;
    max-width: 580px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .features {
    padding: 2rem 0 6rem;
  }
  .features-block {
    background: #3d1f47;
    border: 1px solid rgba(245,239,228,0.08);
    border-radius: 28px;
    padding: 4.5rem 3rem;
    box-shadow:
      0 30px 80px rgba(10,10,20,0.45),
      0 0 0 1px rgba(212,175,55,0.06) inset;
    position: relative;
    overflow: hidden;
  }
  .features-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top right, rgba(212,175,55,0.08), transparent 60%);
    pointer-events: none;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    position: relative;
    z-index: 1;
  }
  .feature h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--accent);
  }
  .feature .num {
    font-family: var(--serif);
    font-style: italic;
    color: var(--accent-deep);
    font-size: 1rem;
    margin-bottom: 0.5rem;
    display: block;
  }
  .feature p { color: rgba(245,239,228,0.75); font-size: 0.95rem; }
  @media (max-width: 768px) {
    .features-block { padding: 3rem 2rem; border-radius: 20px; }
  }

  /* ---- Testimonials section (landing page) ---- */
  .testimonials {
    padding: 6rem 0 4rem;
  }
  .testimonials-eyebrow {
    text-align: center;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }
  .testimonials-summary {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3.5rem;
  }
  .testimonials-rating {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--accent);
    margin-left: 0.4rem;
  }
  .testimonials-count {
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .testimonial-card {
    background: rgba(10,10,10,0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(212,175,55,0.15);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .testimonial-card:hover {
    border-color: rgba(212,175,55,0.35);
    transform: translateY(-2px);
  }
  .testimonial-comment {
    font-family: var(--serif);
    color: rgba(245,239,228,0.92);
    line-height: 1.5;
    font-size: 0.98rem;
    font-style: italic;
    margin: 0;
  }
  .testimonial-image {
    width: 100%;
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
    border-radius: 4px;
    border: 1px solid rgba(212,175,55,0.1);
  }
  .testimonial-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: auto;

  .phone-demo-page {
    padding: 4rem 0 6rem;
    min-height: 90vh;
  }
  .phone-demo-intro {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3.5rem;
  }
  .phone-demo-intro .eyebrow {
    display: inline-block;
    padding: 0.55rem 1.3rem;
    background: linear-gradient(165deg, #4a2557 0%, #3d1f47 50%, #2e1736 100%);

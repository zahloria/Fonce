  const saveBtn = overlay.querySelector('#manage-save-btn');
  const cancelBtn = overlay.querySelector('#manage-cancel-edit');
  const headTitle = overlay.querySelector('#manage-prod-title');
  const headImg = overlay.querySelector('#manage-prod-img');


        toast(labels[opt.dataset.pd] || 'Updated.');
      };
    });

    // Theme picker
    const customPanel = el.querySelector('#custom-colors');
    const ombrePanel = el.querySelector('#ombre-panel');
    const imagePanel = el.querySelector('#image-panel');
    const showPanel = (which) => {
      customPanel.classList.toggle('show', which === 'custom');
      ombrePanel.classList.toggle('show', which === 'ombre');
      imagePanel.classList.toggle('show', which === 'image');
    };

    el.querySelectorAll('.theme-option').forEach(opt => {
      opt.onclick = () => {
        const themeKey = opt.dataset.theme;
        const presetData = THEME_PRESETS[themeKey];
        const isVipFeature = ['custom', 'ombre', 'image'].includes(themeKey) || (presetData && presetData.vip);
        if (isVipFeature && !user.isVip) {
          showUpgradeModal('theme');
          return;
        }
        // Capture whether the previous theme was showing extras (panels)
        const prevPresetData = THEME_PRESETS[user.theme?.preset];
        const wasShowingExtras = !!(prevPresetData && (prevPresetData.live || prevPresetData.texture));
        const willShowExtras = !!(presetData && (presetData.live || presetData.texture));

        if (themeKey === 'custom') {
          if (!user.theme || user.theme.preset !== 'custom') {
            const fallback = THEME_PRESETS[user.theme?.preset] || THEME_PRESETS.fonce;
            user.theme = { ...(user.theme || {}), preset: 'custom', custom: user.theme?.custom || { bg: fallback.bg, fg: fallback.fg, accent: fallback.accent } };
          }
        } else if (themeKey === 'ombre') {
          if (!user.theme || user.theme.preset !== 'ombre') {
            user.theme = { ...(user.theme || {}), preset: 'ombre', ombre: user.theme?.ombre || { color1: '#3d1f47', color2: '#e8a04a', fg: '#f5efe4', accent: '#d4af37' } };
          }
        } else if (themeKey === 'image') {
          if (!user.theme || user.theme.preset !== 'image') {
            user.theme = { ...(user.theme || {}), preset: 'image', image: user.theme?.image || { url: '', fg: '#f5efe4', accent: '#d4af37', overlay: 0.4 } };
          }
        } else {
          user.theme = { ...(user.theme || {}), preset: themeKey };
        }
        save();
        el.querySelectorAll('.theme-option').forEach(o => o.classList.remove('active'));
        opt.classList.add('active');
        showPanel(themeKey === 'custom' || themeKey === 'ombre' || themeKey === 'image' ? themeKey : null);
        toast('Theme updated.');
        // Re-render dashboard if extras need to show or hide (entering OR leaving textured/live themes)
        if (wasShowingExtras || willShowExtras) {
          render();
        }
      };
    });

    // Live mode toggle (only present when current theme supports live)
    const liveToggle = el.querySelector('#live-toggle');
    if (liveToggle) {
      liveToggle.onchange = (e) => {
        if (!user.isVip) {
          e.target.checked = false;
          showUpgradeModal('live');
          return;
        }
        user.theme = { ...(user.theme || {}), live: e.target.checked };
        save();
        toast(e.target.checked ? 'Live mode on.' : 'Live mode off.');
      };
    }

    // Texture color pickers (only present when current theme has a texture)
    const setupTextureColor = (kind) => {
      const colorInput = el.querySelector('#tc-' + kind);
      const textInput = el.querySelector('#tc-' + kind + '-text');
      if (!colorInput || !textInput) return;
      const updateColor = (val) => {
        if (!/^#[0-9a-f]{6}$/i.test(val)) return;
        if (!user.theme.textureColors) user.theme.textureColors = {};
        user.theme.textureColors[kind] = val;
        save();
        // Note: do NOT call applyTheme here — themes only paint on showcase/productDetail views.
        // Saving is enough; the showcase will pick up the new colors when viewed.
      };
      colorInput.oninput = () => {
        textInput.value = colorInput.value;
        updateColor(colorInput.value);
      };
      textInput.oninput = () => {
        if (/^#[0-9a-f]{6}$/i.test(textInput.value)) {
          colorInput.value = textInput.value;
          updateColor(textInput.value);
        }
      };
    };
    setupTextureColor('bg');
    setupTextureColor('fg');
    setupTextureColor('accent');

    const tcResetBtn = el.querySelector('#tc-reset-btn');
    if (tcResetBtn) {
      tcResetBtn.onclick = () => {
        if (user.theme) delete user.theme.textureColors;
        save();
        toast('Texture colors reset.');
        render();
      };
    }

    // Generic color picker sync (paired color input + hex text input)
    const syncColor = (colorId, textId, getThemeObj) => {
      const colorInput = el.querySelector('#' + colorId);
      const textInput = el.querySelector('#' + textId);
      if (!colorInput || !textInput) return;
      const update = (val) => {
        if (!/^#[0-9a-f]{6}$/i.test(val)) return;
        const target = getThemeObj();
        if (!target) return;
        target.value = val;
        target.parent[target.prop] = val;
        save();
      };
      colorInput.oninput = () => {
        textInput.value = colorInput.value;
        update(colorInput.value);
      };
      textInput.oninput = () => {
        if (/^#[0-9a-f]{6}$/i.test(textInput.value)) {
          colorInput.value = textInput.value;
          update(textInput.value);
        }
      };
    };

    // Custom theme color handlers
    const ensureCustom = () => {
      if (!user.theme || user.theme.preset !== 'custom') {
        user.theme = { ...(user.theme || {}), preset: 'custom', custom: user.theme?.custom || { bg: '#0a0806', fg: '#f5efe4', accent: '#c9a961' } };
      }
      return user.theme.custom;
    };
    syncColor('cc-bg', 'cc-bg-text', () => ({ parent: ensureCustom(), prop: 'bg' }));
    syncColor('cc-fg', 'cc-fg-text', () => ({ parent: ensureCustom(), prop: 'fg' }));
    syncColor('cc-acc', 'cc-acc-text', () => ({ parent: ensureCustom(), prop: 'accent' }));

    // Ombre theme color handlers
    const ensureOmbre = () => {
      if (!user.theme || user.theme.preset !== 'ombre') {
        user.theme = { ...(user.theme || {}), preset: 'ombre', ombre: user.theme?.ombre || { color1: '#3d1f47', color2: '#e8a04a', fg: '#f5efe4', accent: '#d4af37' } };
      }
      return user.theme.ombre;
    };
    syncColor('om-c1', 'om-c1-text', () => ({ parent: ensureOmbre(), prop: 'color1' }));
    syncColor('om-c2', 'om-c2-text', () => ({ parent: ensureOmbre(), prop: 'color2' }));
    syncColor('om-fg', 'om-fg-text', () => ({ parent: ensureOmbre(), prop: 'fg' }));
    syncColor('om-acc', 'om-acc-text', () => ({ parent: ensureOmbre(), prop: 'accent' }));

    // Image theme handlers
    const ensureImage = () => {
      if (!user.theme || user.theme.preset !== 'image') {
        user.theme = { ...(user.theme || {}), preset: 'image', image: user.theme?.image || { url: '', fg: '#f5efe4', accent: '#d4af37', overlay: 0.4 } };
      }
      return user.theme.image;
    };
    syncColor('im-fg', 'im-fg-text', () => ({ parent: ensureImage(), prop: 'fg' }));
    syncColor('im-acc', 'im-acc-text', () => ({ parent: ensureImage(), prop: 'accent' }));

    // Image URL input (live update on type)
    const urlInput = el.querySelector('#im-url');
    if (urlInput) {
      urlInput.oninput = () => {
        const val = urlInput.value.trim();
        if (val && !/^https?:\/\//i.test(val)) return;
        ensureImage().url = val;
        save();
      };
    }

    // Image file upload — read as base64 data URL
    const fileInput = el.querySelector('#im-file');
    const fileBtn = el.querySelector('#im-file-btn');
    if (fileBtn && fileInput) {
      fileBtn.onclick = () => fileInput.click();
      fileInput.onchange = (e) => {
        const file = e.target.files?.[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) {
          toast('Image too large. Try under 5MB or use a URL instead.');
          return;
        }
        if (file.size > 2 * 1024 * 1024) {
          toast('Large image — may slow your showcase. Smaller is better.');
        }
        const reader = new FileReader();
        reader.onload = (ev) => {
          ensureImage().url = ev.target.result;
          save();
          if (urlInput) urlInput.value = '';
          toast('Image uploaded.');
        };
        reader.onerror = () => toast('Failed to read file.');
        reader.readAsDataURL(file);
      };
    }

    // Overlay strength slider
    const overlayInput = el.querySelector('#im-overlay');
    const overlayOut = el.querySelector('#im-overlay-out');
    if (overlayInput && overlayOut) {
      overlayInput.oninput = () => {
        const pct = parseInt(overlayInput.value, 10);
        overlayOut.textContent = pct + '%';
        ensureImage().overlay = pct / 100;
        save();
      };
    }

    // Font picker
    el.querySelectorAll('.font-option').forEach(opt => {
      opt.onclick = () => {
        const fontKey = opt.dataset.font;
        if (fontKey !== 'fonce' && !user.isVip) {
          showUpgradeModal('font');
          return;
        }
        user.theme = { ...(user.theme || { preset: 'fonce' }), font: fontKey };
        save();
        el.querySelectorAll('.font-option').forEach(o => o.classList.remove('active'));
        opt.classList.add('active');
        toast('Typography updated.');
      };
    });

    const copyLinkEl = el.querySelector('#copy-link');
    const copyBtnEl = el.querySelector('#share-link-copy-btn');
    const doCopy = () => {
      navigator.clipboard?.writeText(link).then(() => {
        toast('Link copied.');
        if (copyBtnEl) {
          const span = copyBtnEl.querySelector('span');
          if (span) {
            const original = span.textContent;
            span.textContent = 'Copied';
            copyBtnEl.classList.add('copied');
            setTimeout(() => {
              span.textContent = original;
              copyBtnEl.classList.remove('copied');
            }, 1600);
          }
        }
      });
    };
    if (copyLinkEl) copyLinkEl.onclick = doCopy;
    if (copyBtnEl) copyBtnEl.onclick = (e) => { e.stopPropagation(); doCopy(); };

    // Insights toggle
    const insightsBtn = el.querySelector('#insights-toggle');
    const insightsPanel = el.querySelector('#insights-panel');
    if (insightsBtn && insightsPanel) {
      insightsBtn.onclick = () => {
        const isOpen = insightsPanel.classList.toggle('open');
        insightsBtn.classList.toggle('open', isOpen);
      };
    }

    // Locked insight cards (Views/Clicks) trigger upgrade modal
    el.querySelectorAll('.insight.locked').forEach(card => {
      card.onclick = () => showUpgradeModal('insights');
    });

    // Remove product handlers — instant removal with Undo
    el.querySelectorAll('.remove-btn').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        const productId = btn.dataset.productId;
        const user = state.users[state.currentUser];
        const productIndex = user.products.findIndex(p => p.id === productId);
        if (productIndex === -1) return;
        // Save snapshot for undo
        const removedProduct = user.products[productIndex];
        const removedIndex = productIndex;
        removeProduct(productId);
        toastWithUndo('Product removed.', () => {
          // Restore at original position
          const u = state.users[state.currentUser];
          if (u && !u.products.some(p => p.id === removedProduct.id)) {
            u.products.splice(removedIndex, 0, removedProduct);
            save();
            render();
            toast('Restored.');
          }
        });
        render();
      };
    });

    // Archive / Unarchive handlers
    el.querySelectorAll('.archive-btn').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        const productId = btn.dataset.productId;
        const action = btn.dataset.action;
        setProductArchived(productId, action === 'archive');
        toast(action === 'archive' ? 'Product archived. Hidden from your showcase.' : 'Product unarchived. Now live on your showcase.');
        render();
      };
    });

    // Refresh paused product handlers
    el.querySelectorAll('.refresh-btn').forEach(btn => {
      btn.onclick = async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const productId = btn.dataset.productId;
        btn.disabled = true;
        btn.textContent = 'Refreshing...';
        const result = await refreshProduct(productId);
        if (result.ok) {
          toast('Product refreshed and republished.');
          render();
        } else {
          btn.disabled = false;
          btn.textContent = 'Refresh & republish';
          toast('Refresh failed: ' + (result.error || 'try again later'));
        }
      };
    });

    // Tap product card → open manage modal with reviews
    el.querySelectorAll('.product-card-mini').forEach(card => {
      card.onclick = (e) => {
        if (e.target.closest('button')) return;
        const productId = card.dataset.productId;
        if (productId) showProductManage(productId);
      };
    });

    // Verify prices handler — runs through every product with a source URL
    const verifyBtn = el.querySelector('#verify-prices-btn');
    if (verifyBtn) {
      verifyBtn.onclick = async () => {
        const targets = user.products.filter(p => p.sourceUrl && /^https?:\/\//i.test(p.sourceUrl));
        if (targets.length === 0) {
          toast('No products with source URLs to check.');
          return;
        }
        const overlay = $(`
          <div class="verify-overlay">
            <div class="verify-modal">
              <h3>Verifying prices</h3>
              <p>Checking each source URL for changes. This may take a moment.</p>
              <div class="verify-progress-bar"><div class="verify-progress-fill" id="vfill" style="width:0%"></div></div>
              <div class="verify-progress-text" id="vtext">Starting...</div>
            </div>
          </div>
        `);
        document.body.appendChild(overlay);
        const fill = overlay.querySelector('#vfill');
        const text = overlay.querySelector('#vtext');
        const result = await verifyAllProducts((current, total, title) => {
          fill.style.width = `${(current / total) * 100}%`;
          text.textContent = `Checking ${current} of ${total}: ${title.slice(0, 40)}${title.length > 40 ? '...' : ''}`;
        });
        overlay.remove();
        let msg;
        if (result.paused === 0 && result.failed === 0) {
          msg = `All ${result.checked} products verified — no changes detected.`;
        } else if (result.paused > 0) {
          msg = `${result.paused} product${result.paused > 1 ? 's' : ''} paused due to price changes. ${result.failed} couldn't be checked.`;
        } else {
          msg = `${result.checked - result.failed} verified, ${result.failed} couldn't be checked (some sites block fetchers).`;
        }
        toast(msg);
        render();
      };
    }
  }, 0);

  return el;
}


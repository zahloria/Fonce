      <button class="btn" onclick="navigate('landing')">Back to Fonce</button>
    </div>
  `);
  // Auto-open review modal: product review (single buy) or site review (cart)
  if (purchase) {
    setTimeout(() => {
      if (purchase.type === 'single') {
        showPurchaseReviewModal(purchase);
      } else if (purchase.type === 'cart') {
        showSiteReviewModal();
      }
      state.lastPurchase = null;
      save();
    }, 1500);
  }
  return el;
}


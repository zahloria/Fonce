// ScrapingBee API key — used to fetch product pages bypassing anti-bot.
// SECURITY NOTE: this key is visible in the deployed HTML. Acceptable for
// the private prototype phase. When moving to production / public launch,
// route ScrapingBee calls through a backend so the key isn't exposed.
const SCRAPINGBEE_KEY = 'IP948RVR8ZQ82RYN40AZZ410O9OBRP7KOB13AGOQFMCEICLLCO7DC44BBRGTC0NP7BD8UDIPAENTO04Y';

// Fetch page HTML via ScrapingBee (renders JS, bypasses anti-bot).
// `premium` param uses premium proxies (eats more credits but works on hostile sites like AliExpress).
async function tryScrapingBee(url, opts = {}) {
  if (!SCRAPINGBEE_KEY) throw new Error('No ScrapingBee key configured');
  const premium = opts.premium !== false; // default to premium for reliability
  const params = new URLSearchParams({
    api_key: SCRAPINGBEE_KEY,
    url: url,
    render_js: 'true',
    premium_proxy: premium ? 'true' : 'false',
    country_code: 'us'
  });
  const resp = await fetch(`https://app.scrapingbee.com/api/v1/?${params.toString()}`);
  if (!resp.ok) {
    const errText = await resp.text().catch(() => '');
    throw new Error(`ScrapingBee ${resp.status}: ${errText.slice(0, 200)}`);
  }
  const html = await resp.text();
  if (!html || html.length < 200) throw new Error('ScrapingBee returned empty');
  return html;
}

// Extract AliExpress variants from rendered HTML.
// AliExpress embeds product data in window.runParams or inline scripts.
// We look for the SKU array with current sale prices per variant.
function extractAliExpressVariants(html) {
  const variants = [];
  try {
    // Format A: skuProductPropertyList + skuPriceList (most common)
    const skuPropsMatch = html.match(/skuProductPropertyList["']?\s*[:=]\s*(\[[\s\S]*?\])\s*[,\}]/);
    const skuListMatch = html.match(/skuPriceList["']?\s*[:=]\s*(\[[\s\S]*?\])\s*[,\}]/);
    if (skuPropsMatch && skuListMatch) {
      const props = JSON.parse(skuPropsMatch[1]);
      const list = JSON.parse(skuListMatch[1]);
      for (const sku of list) {
        const labelParts = [];
        const skuPropIds = (sku.skuPropIds || sku.skuAttr || '').toString();
        for (const prop of props) {
          const val = (prop.skuPropertyValues || []).find(v =>
            skuPropIds.includes(`#${v.propertyValueId}`) ||
            skuPropIds.includes(v.propertyValueIdLong)
          );
          if (val) labelParts.push(val.propertyValueDisplayName || val.propertyValueName);
        }
        // Try multiple price paths — AliExpress changes their format often
        const priceCandidates = [
          sku.skuVal?.actSkuCalPrice,
          sku.skuVal?.skuActivityAmount?.value,
          sku.skuVal?.skuAmount?.value,
          sku.skuVal?.skuCalPrice,
          sku.skuVal?.actSkuMultiCurrencyCalPrice,
          sku.salePrice?.minActivityAmount?.value,
          sku.salePrice?.minPrice?.value,
        ];
        let price = null;
        for (const cand of priceCandidates) {
          if (cand != null) {
            const p = parseFloat(String(cand).replace(/[^0-9.]/g, ''));
            if (!isNaN(p) && p > 0) { price = p; break; }
          }
        }
        variants.push({
          sku: String(sku.skuId || sku.skuIdStr || ''),
          label: labelParts.join(' · ') || 'Variant',
          price: price
        });
      }
    }
    // Format B: simpler sku array fallback
    if (variants.length === 0) {
      const altMatch = html.match(/skus?\s*[:=]\s*(\[[\s\S]{0,5000}?\])\s*[,\}]/i);
      if (altMatch) {
        try {
          const parsed = JSON.parse(altMatch[1]);
          for (const item of parsed.slice(0, 30)) {
            if (item && (item.sku_id || item.skuId || item.id)) {
              variants.push({
                sku: String(item.sku_id || item.skuId || item.id),
                label: item.name || item.title || item.spec || 'Variant',
                price: parseFloat(item.price || item.sale_price || item.skuCalPrice) || null
              });
            }
          }
        } catch (e) {}
      }
    }
  } catch (e) {
    console.warn('[Fonce] Variant extraction failed:', e.message);
  }
  return variants;
}

// Extract a raw price from AliExpress HTML when structured data fails.
// AliExpress embeds prices in many different JSON keys depending on the product/region.
// Returns the cheapest plausible USD-like price found (current sale price).
function extractAliExpressRawPrice(html) {
  const candidates = [];
  const pushPrice = (raw) => {
    if (raw == null) return;
    const p = parseFloat(String(raw).replace(/[^0-9.]/g, ''));
    if (!isNaN(p) && p > 0 && p < 100000) candidates.push(p);
  };

  // Patterns that AliExpress uses for the CURRENT sale price (not pre-discount)
  const patterns = [
    /"formattedActivityPrice":\s*"\$?([\d.,]+)/g,
    /"formattedPrice":\s*"\$?([\d.,]+)/g,
    /"actSkuMultiCurrencyDisplayPrice":\s*"\$?([\d.,]+)/g,
    /"actSkuCalPrice":\s*"?([\d.]+)/g,
    /"skuActivityAmount":\s*\{\s*"value":\s*([\d.]+)/g,
    /"minActivityAmount":\s*\{\s*"value":\s*([\d.]+)/g,
    /"discountPrice":\s*\{?\s*"?(?:value|amount)"?:\s*"?([\d.]+)/g,
    /"salePrice":\s*"?\$?([\d.]+)/g,
    /"productSalePrice":\s*"?\$?([\d.]+)/g,
  ];
  for (const re of patterns) {
    let m;
    while ((m = re.exec(html)) !== null) pushPrice(m[1]);
  }

  if (candidates.length === 0) return null;
  // Return the most common (mode) or the minimum — both work to dodge inflated prices
  // Use the median for robustness against outliers
  candidates.sort((a, b) => a - b);
  return candidates[Math.floor(candidates.length / 2)];
}

// Parse AliExpress URL params to figure out which variant the creator copied.
// pdp_npi format: 6@dis!USD!sale!discount!!!original!shipping!... ID@variant_offset
// Returns { price, skuHint } — price is the variant's sale price, skuHint helps match
function tryParseAliExpressUrl(url) {
  if (!/aliexpress\./i.test(url)) return null;
  try {
    const u = new URL(url);
    // First try direct sku_id query param
    const skuId = u.searchParams.get('sku_id') || u.searchParams.get('skuId');
    const npi = u.searchParams.get('pdp_npi');
    if (!npi) return skuId ? { price: null, skuHint: skuId } : null;
    const parts = npi.split('!');
    let price = null;
    for (let i = 0; i < parts.length - 1; i++) {
      if (/^(USD|EUR|GBP|JPY|CAD|AUD|MXN|BRL|RUB|CNY|INR)$/i.test(parts[i])) {
        const p = parseFloat(parts[i + 1]);
        if (!isNaN(p) && p > 0) { price = p; break; }
      }
    }
    return { price, skuHint: skuId };
  } catch (e) {
    return null;
  }
}

function tryExtractPrice(data) {
  const candidates = [data?.price, data?.product?.price, data?.data?.price];
  for (const c of candidates) {
    if (typeof c === 'number') return c;
    if (typeof c === 'string') {
      const m = c.match(/[\d]+(\.[\d]+)?/);
      if (m) return parseFloat(m[0]);
    }
  }
  const text = `${data?.title || ''} ${data?.description || ''}`;
  const m = text.match(/\$\s?([\d,]+(?:\.\d{2})?)/);
  if (m) return parseFloat(m[1].replace(/,/g, ''));
  return null;
}

function decodeHtmlEntities(s) {
  if (!s) return s;
  return s
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&#039;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&apos;/g, "'");
}

function parseHtmlMeta(html) {
  const get = (re) => {
    const m = html.match(re);
    return m ? decodeHtmlEntities(m[1]) : null;
  };

  // ----- JSON-LD structured data (most reliable) -----
  let ldPrice = null, ldImage = null, ldTitle = null, ldDesc = null;
  try {
    const blocks = [...html.matchAll(/<script[^>]*type=["']application\/ld\+json["'][^>]*>([\s\S]*?)<\/script>/gi)];
    const visit = (node) => {
      if (!node || typeof node !== 'object') return;
      const types = Array.isArray(node['@type']) ? node['@type'] : [node['@type']];
      if (types.some(t => typeof t === 'string' && t.toLowerCase().includes('product'))) {
        const offers = Array.isArray(node.offers) ? node.offers[0] : node.offers;
        const p = offers?.price ?? offers?.lowPrice ?? offers?.priceSpecification?.price;
        if (p != null && !ldPrice) ldPrice = parseFloat(String(p).replace(/[^0-9.]/g, ''));
        if (!ldImage) {
          const img = Array.isArray(node.image) ? node.image[0] : node.image;
          ldImage = typeof img === 'string' ? img : img?.url;
        }
        if (!ldTitle) ldTitle = node.name;
        if (!ldDesc) ldDesc = node.description;
      }
      if (node['@graph']) node['@graph'].forEach(visit);
      // Recurse into nested objects
      for (const k in node) {
        if (typeof node[k] === 'object') visit(node[k]);
      }
    };
    for (const b of blocks) {
      try {
        const parsed = JSON.parse(b[1]);
        (Array.isArray(parsed) ? parsed : [parsed]).forEach(visit);
      } catch (e) {}
    }
  } catch (e) {}

  // ----- Microdata (itemprop) -----
  const microPrice = get(/itemprop=["']price["'][^>]*content=["']([\d.,]+)["']/i)
    || get(/content=["']([\d.,]+)["'][^>]*itemprop=["']price["']/i);

  // ----- Open Graph + product price meta -----
  const metaPrice =
    get(/<meta[^>]+property=["']product:price:amount["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+content=["']([^"']+)["'][^>]+property=["']product:price:amount["']/i) ||
    get(/<meta[^>]+property=["']og:price:amount["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+name=["']twitter:data1["'][^>]+content=["']\$?([\d.,]+)["']/i) ||
    get(/<meta[^>]+name=["']price["'][^>]+content=["']\$?([\d.,]+)["']/i);

  // ----- Data attributes (Shopify, WooCommerce common patterns) -----
  const dataAttrPrice = get(/data-product-price=["']([\d.,]+)["']/i)
    || get(/data-price=["']([\d.,]+)["']/i)
    || get(/"price_amount":\s*"?([\d.,]+)/i)
    || get(/"amount":\s*"?([\d.,]+)/i);

  let price = ldPrice;
  if (!price && microPrice) price = parseFloat(microPrice.replace(/,/g, ''));
  if (!price && metaPrice) price = parseFloat(String(metaPrice).replace(/[^0-9.]/g, ''));
  if (!price && dataAttrPrice) price = parseFloat(String(dataAttrPrice).replace(/,/g, ''));

  // ----- Title fallback chain -----
  const title = ldTitle ||
    get(/<meta[^>]+property=["']og:title["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:title["']/i) ||
    get(/<meta[^>]+name=["']twitter:title["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+itemprop=["']name["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<title>([^<]+)<\/title>/i) ||
    get(/<h1[^>]*>([^<]+)<\/h1>/i);

  // ----- Image fallback chain -----
  const image = ldImage ||
    get(/<meta[^>]+property=["']og:image:secure_url["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+property=["']og:image:url["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+property=["']og:image["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+content=["']([^"']+)["'][^>]+property=["']og:image["']/i) ||
    get(/<meta[^>]+name=["']twitter:image["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+name=["']twitter:image:src["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+itemprop=["']image["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<link[^>]+rel=["']image_src["'][^>]+href=["']([^"']+)["']/i);

  // ----- Description -----
  const description = ldDesc ||
    get(/<meta[^>]+property=["']og:description["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+name=["']twitter:description["'][^>]+content=["']([^"']+)["']/i) ||
    get(/<meta[^>]+name=["']description["'][^>]+content=["']([^"']+)["']/i);

  return {
    title: title ? title.trim() : null,
    image: image ? image.trim() : null,
    description: description ? description.trim() : null,
    price: price && !isNaN(price) && price > 0 ? price : null
  };
}

// Site-specific URL parser: AliExpress encodes price in pdp_npi param
// Format: !CCY!current!discount!!!original!shipping! e.g. !USD!14.47!7.26!!!98.35!49.34!
function tryParseAliExpressUrl(url) {
  try {
    if (!/aliexpress\./i.test(url)) return null;
    // Try the URL params first
    const u = new URL(url);
    const candidates = [
      u.searchParams.get('pdp_npi'),
      u.searchParams.get('skuPrice'),
      // Also check fragment / hash in case URL structure varies
      u.hash
    ].filter(Boolean);
    for (const candidate of candidates) {
      const parts = candidate.split('!');
      for (let i = 0; i < parts.length - 1; i++) {
        if (/^(USD|EUR|GBP|JPY|CAD|AUD|MXN|BRL|RUB|CNY|INR)$/i.test(parts[i])) {
          const price = parseFloat(parts[i + 1]);
          if (!isNaN(price) && price > 0) return price;
        }
      }
    }
  } catch (e) {}
  return null;
}

function isAliExpressUrl(url) {
  return /aliexpress\./i.test(url || '');
}

// CORS proxy adapters — each takes a target URL, returns raw HTML or throws.
const HTML_PROXIES = [
  {
    name: 'allorigins',
    fetch: async (url) => {
      const r = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`);
      const j = await r.json();
      if (!j.contents) throw new Error('empty');
      return j.contents;
    }
  },
  {
    name: 'corsproxy',
    fetch: async (url) => {
      const r = await fetch(`https://corsproxy.io/?${encodeURIComponent(url)}`);
      if (!r.ok) throw new Error('status ' + r.status);
      const html = await r.text();
      if (!html || html.length < 100) throw new Error('empty');
      return html;
    }
  },
  {
    name: 'codetabs',
    fetch: async (url) => {
      const r = await fetch(`https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(url)}`);
      if (!r.ok) throw new Error('status ' + r.status);
      const html = await r.text();
      if (!html || html.length < 100) throw new Error('empty');
      return html;
    }
  },
  {
    name: 'thingproxy',
    fetch: async (url) => {
      const r = await fetch(`https://thingproxy.freeboard.io/fetch/${url}`);
      if (!r.ok) throw new Error('status ' + r.status);
      const html = await r.text();
      if (!html || html.length < 100) throw new Error('empty');
      return html;
    }
  }
];

async function tryProxiesInParallel(url) {
  const settled = await Promise.allSettled(
    HTML_PROXIES.map(p => p.fetch(url))
  );
  const htmls = settled
    .map((r, i) => r.status === 'fulfilled' ? { name: HTML_PROXIES[i].name, html: r.value } : null)
    .filter(Boolean);
  if (htmls.length === 0) {
    const failures = settled.map((r, i) => `${HTML_PROXIES[i].name}: ${r.reason?.message || 'failed'}`).join('; ');
    throw new Error('All HTML proxies failed (' + failures + ')');
  }
  console.log('[Fonce] Successful proxies:', htmls.map(h => h.name).join(', '));
  // Parse each successful response, merge taking the first non-null for each field
  let merged = { title: null, image: null, description: null, price: null };
  for (const { html } of htmls) {
    try {
      const m = parseHtmlMeta(html);
      merged.title = merged.title || m.title;
      merged.image = merged.image || m.image;
      merged.description = merged.description || m.description;
      merged.price = merged.price || m.price;
    } catch (e) {}
  }
  return merged;
}

async function tryMicrolink(url) {
  const resp = await fetch(`https://api.microlink.io/?url=${encodeURIComponent(url)}`);
  const json = await resp.json();
  if (json.status !== 'success') throw new Error(json.message || 'microlink ' + json.status);
  const d = json.data || {};
  return {
    title: d.title || null,
    image: d.image?.url || d.logo?.url || null,
    description: d.description || null,
    price: tryExtractPrice(d)
  };
}

async function fetchProductData(url) {
  if (!url || !/^https?:\/\//i.test(url)) throw new Error('Invalid URL');

  let result = { title: null, image: null, description: null, price: null, variants: [] };
  let strategiesFired = [];
  let scrapingBeeHtml = null;

  // Strategy 1 (PRIMARY): ScrapingBee with JS rendering + premium proxies
  // Handles AliExpress, Amazon-style hostile sites, JS-rendered pages.
  try {
    scrapingBeeHtml = await tryScrapingBee(url, { premium: true });
    const m = parseHtmlMeta(scrapingBeeHtml);
    result.title = result.title || m.title;
    result.image = result.image || m.image;
    result.description = result.description || m.description;
    result.price = result.price || m.price;
    strategiesFired.push('scrapingbee');
  } catch (e) {
    console.warn('[Fonce] ScrapingBee failed:', e.message);
  }

  // Strategy 2: AliExpress — variant extraction + raw price fallback
  // We OVERRIDE the meta-parsed price for AliExpress because JSON-LD often
  // returns the pre-discount/list price, not the current sale price.
  // We do NOT auto-pick the variant the creator was viewing — they choose
  // which variant they want to sell in the picker UI.
  if (scrapingBeeHtml && /aliexpress\./i.test(url)) {
    try {
      const variants = extractAliExpressVariants(scrapingBeeHtml);
      if (variants.length > 0) {
        result.variants = variants;
        const variantPrices = variants.map(v => v.price).filter(p => p && p > 0);
        if (variantPrices.length > 0) {
          // Use lowest variant price as the placeholder source price.
          // Creator will pick a variant which updates the price.
          // OVERRIDES the meta price since AliExpress meta often has pre-discount price.
          result.price = Math.min(...variantPrices);
          strategiesFired.push('aliexpress-variant-min($' + result.price.toFixed(2) + ')');
        }
        strategiesFired.push('aliexpress-variants(' + variants.length + ')');
      } else {
        // No variants extracted — try our raw price patterns on the HTML
        const rawPrice = extractAliExpressRawPrice(scrapingBeeHtml);
        if (rawPrice) {
          result.price = rawPrice; // OVERRIDES potentially-inflated JSON-LD price
          strategiesFired.push('aliexpress-raw-price($' + rawPrice.toFixed(2) + ')');
        } else {
          // Last resort for AliExpress: URL pdp_npi price (the user-viewed price)
          const urlHint = tryParseAliExpressUrl(url);
          if (urlHint && urlHint.price) {
            result.price = urlHint.price;
            strategiesFired.push('aliexpress-url-price($' + urlHint.price.toFixed(2) + ')');
          }
        }
      }
    } catch (e) {
      console.warn('[Fonce] AliExpress extract failed:', e.message);
    }
  }

  // Strategy 3 (FALLBACK): Free CORS proxies — only if ScrapingBee was incomplete
  // Used as backup since they fail on hostile sites but sometimes work for simple ones.
  if (!result.title || !result.image || !result.price) {
    try {
      const proxyResult = await tryProxiesInParallel(url);
      result.title = result.title || proxyResult.title;
      result.image = result.image || proxyResult.image;
      result.description = result.description || proxyResult.description;
      result.price = result.price || proxyResult.price;
      strategiesFired.push('free-proxies');
    } catch (e) {
      console.warn('[Fonce] Free proxies failed:', e.message);
    }
  }

  // Strategy 4 (LAST RESORT): Microlink for whatever's still missing
  if (!result.title || !result.image || !result.price) {
    try {
      const ml = await tryMicrolink(url);
      result.title = result.title || ml.title;
      result.image = result.image || ml.image;
      result.description = result.description || ml.description;
      result.price = result.price || ml.price;
      strategiesFired.push('microlink');
    } catch (e) {
      console.warn('[Fonce] Microlink failed:', e.message);
    }
  }

  // Strategy 5: AliExpress URL hint (price from URL params) — last resort
  if (!result.price) {
    const urlHint = tryParseAliExpressUrl(url);
    if (urlHint && urlHint.price) {
      result.price = urlHint.price;
      strategiesFired.push('aliexpress-url-fallback');
    }
  }

  console.log('[Fonce] Fetch strategies fired:', strategiesFired.join(', '), '| Result:', result);

  if (!result.title && !result.image && !result.price) {
    throw new Error('Could not extract product data. The site may block scrapers — fill in manually.');
  }

  return result;
}

/* ============================================================
   PRODUCT MONITORING — verify & refresh
   ============================================================ */
async function verifyAllProducts(onProgress) {
  const user = state.users[state.currentUser];
  const targets = user.products.filter(p => p.sourceUrl && /^https?:\/\//i.test(p.sourceUrl));
  let pausedCount = 0;
  let unchangedCount = 0;
  let failedCount = 0;
  for (let i = 0; i < targets.length; i++) {
    const product = targets[i];
    if (onProgress) onProgress(i + 1, targets.length, product.title);
    try {
      const data = await fetchProductData(product.sourceUrl);
      product.lastChecked = Date.now();
      if (data && data.price && Math.abs(data.price - product.sourcePrice) > 0.01) {
        product.paused = true;
        product.pausedReason = 'price_changed';
        product.detectedNewPrice = data.price;
        pausedCount++;
      } else {
        unchangedCount++;
      }
    } catch (e) {
      failedCount++;
      console.warn('[Fonce] Verify failed for', product.title, e);
    }
  }
  save();
  return { checked: targets.length, paused: pausedCount, unchanged: unchangedCount, failed: failedCount };
}

async function refreshProduct(productId) {
  const user = state.users[state.currentUser];
  const product = user.products.find(p => p.id === productId);
  if (!product || !product.sourceUrl) return { ok: false, error: 'No source URL' };
  try {
    const data = await fetchProductData(product.sourceUrl);
    if (!data) return { ok: false, error: 'Fetch returned nothing' };
    if (data.price) product.sourcePrice = data.price;
    if (data.image) product.image = data.image;
    if (data.title && !product.title) product.title = data.title;
    product.listedPrice = +(product.sourcePrice + product.markup).toFixed(2);
    product.paused = false;
    product.pausedReason = null;
    product.detectedNewPrice = null;
    product.lastChecked = Date.now();
    save();
    return { ok: true };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

